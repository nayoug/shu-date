<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('partials/document-head', {
    pageTitle: '注销账号',
    accountPage: true
  }) %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container account-container">
    <div class="card account-card">
      <h2 class="account-title">🗑️ 注销账号确认</h2>

      <div class="warning-callout">
        <p>
          <strong>⚠️ 注意：</strong>注销后，您的恋爱人格测试结果、匹配记录以及所有个人资料将被永久删除，无法恢复。
        </p>
      </div>

      <% if (typeof deleteMessage !== 'undefined' && deleteMessage) { %>
        <div class="alert alert-<%= deleteMessageType || 'error' %> form-group--compact">
          <%= deleteMessage %>
        </div>
      <% } %>

      <form action="/settings/delete" method="POST">
        <div class="form-group form-group--compact">
          <label>邮箱</label>
          <input type="email" name="email" placeholder="请输入您的邮箱">
        </div>

        <div class="form-group form-group--final">
          <label>密码</label>
          <input type="password" name="password" placeholder="请输入您的密码">
        </div>

        <% if (typeof csrfToken !== 'undefined') { %>
          <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
        <% } %>
        <button type="submit" class="btn btn-danger">确认注销账号</button>
      </form>

      <div class="account-link-row">
        <a href="/settings" class="account-link">← 返回设置</a>
      </div>
    </div>
  </div>
  <%- include('partials/site-footer') %>
</body>
</html>
