<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/head-icons') %>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">心有所<span>SHU</span></a>
    </div>
  </nav>

  <div class="container" style="max-width: 400px; padding-top: 80px;">
    <div class="card">
      <h2 style="text-align: center; margin-bottom: 6px;">忘记密码</h2>
      <p style="text-align: center; color: var(--muted-foreground); font-size: 0.9rem; margin-bottom: 28px;">
        输入你的学校邮箱
      </p>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-<%= messageType || 'info' %>">
          <%- message %>
        </div>
      <% } %>

      <form action="/forgot" method="POST" onsubmit="return handleForgotSubmit(event)">
        <div class="form-group">
          <div style="display: flex; align-items: center; gap: 0;">
            <input type="text" id="emailPrefix" placeholder="请输入学校邮箱" value="<%= typeof email !== 'undefined' && email ? email.replace('@shu.edu.cn', '') : '' %>" required style="flex: 1; text-align: center; font-size: 16px; border-radius: 6px 0 0 6px; border-right: none;">
            <span style="background: #f0f0f0; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 0 6px 6px 0; color: #666; font-size: 14px; white-space: nowrap;">@shu.edu.cn</span>
          </div>
          <input type="hidden" name="email" id="emailFull">
        </div>
        <button type="submit" class="btn" style="width: 100%;">发送重置链接</button>
      </form>

      <p style="text-align: center; margin-top: 20px;">
        <a href="/login" style="color: var(--primary);">← 返回登录</a>
      </p>
    </div>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>
  <script>
  function handleForgotSubmit(e) {
    const prefix = document.getElementById('emailPrefix').value.trim();
    if (!prefix) {
      alert('请输入学校邮箱');
      return false;
    }
    document.getElementById('emailFull').value = prefix + '@shu.edu.cn';
    return true;
  }
  </script>
</body>
</html>
