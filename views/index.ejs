<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>心有所SHU - 上大交友匹配</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= messageType || 'info' %>"><%= message %></div>
    <% } %>

    <div class="hero">
      <h1>心有所SHU</h1>
      <p class="subtitle">上大同学之间的互相认识，从这里开始</p>
      <p style="opacity: 0.7; font-size: 0.9rem;">小范围内测中</p>
      <% if (typeof user === 'undefined' || !user) { %>
        <a href="/login" class="btn btn-large" style="background: white; color: var(--primary); margin-top: 20px;">开始</a>
      <% } %>
    </div>

    <div class="features">
      <div class="feature-card">
        <div class="icon">📧</div>
        <h3>学校邮箱</h3>
        <p>@shu.edu.cn 验证身份</p>
      </div>
      <div class="feature-card">
        <div class="icon">✏️</div>
        <h3>填个问卷</h3>
        <p>说说你的性格和爱好</p>
      </div>
      <div class="feature-card">
        <div class="icon">💕</div>
        <h3>每周推荐</h3>
        <p>认识一个可能聊得来的人</p>
      </div>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
    <div class="card">
      <h3 style="margin-bottom: 12px;">Hi, <%= user.name || user.email.split('@')[0] %></h3>
      <% if (!user.verified) { %>
        <div class="alert alert-warning" style="margin-bottom: 16px;">
          邮箱还没验证，去邮箱里点一下验证链接
        </div>
      <% } else { %>
        <% if (user.hasProfile) { %>
          <p style="color: var(--muted-foreground); margin-bottom: 16px;">资料填好了，等匹配结果吧</p>
          <a href="/matches" class="btn">看看匹配</a>
        <% } else { %>
          <p style="color: var(--muted-foreground); margin-bottom: 16px;">还差个问卷没填</p>
          <a href="/profile" class="btn">去填</a>
        <% } %>
      <% } %>
    </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>

  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <style>
    .dev-tool-btn {
      position: fixed;
      top: 15px;
      right: 15px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      cursor: pointer;
      font-size: 16px;
      box-shadow: 0 2px 10px rgba(102, 126, 234, 0.4);
      z-index: 9999;
    }
    .dev-tool-btn:hover { transform: scale(1.1); }
    .dev-modal {
      display: none;
      position: fixed;
      top: 60px;
      right: 15px;
      width: 300px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      z-index: 9998;
      overflow: hidden;
    }
    .dev-modal.show { display: block; }
    .dev-modal-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 12px 16px;
      font-weight: bold;
      display: flex;
      justify-content: space-between;
    }
    .dev-modal-header .close-btn {
      background: none;
      border: none;
      color: white;
      font-size: 18px;
      cursor: pointer;
    }
    .dev-modal-body { padding: 16px; }
    .dev-section { margin-bottom: 16px; }
    .dev-section:last-child { margin-bottom: 0; }
    .dev-section-title { font-size: 12px; color: #888; margin-bottom: 8px; }
    .dev-btn {
      display: block;
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 8px;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      background: #f8f9fa;
      color: #333;
      text-decoration: none;
      text-align: center;
    }
    .dev-btn:hover { background: #667eea; color: white; border-color: #667eea; }
    .dev-btn.primary { background: #667eea; color: white; border-color: #667eea; }
    .dev-info { font-size: 12px; color: #666; background: #f0f0f0; padding: 8px 10px; border-radius: 6px; }
    .dev-badge { background: #4caf50; color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px; margin-left: 8px; }
  </style>
  <button class="dev-tool-btn" onclick="toggleDevModal()">🔧</button>
  <div class="dev-modal" id="devModal">
    <div class="dev-modal-header">
      <span>🛠️ 开发者工具<span class="dev-badge">DEV</span></span>
      <button class="close-btn" onclick="toggleDevModal()">×</button>
    </div>
    <div class="dev-modal-body">
      <% if (typeof isDev !== 'undefined' && isDev) { %>
      <div class="dev-section">
        <div class="dev-section-title">环境信息</div>
        <div class="dev-info"><strong>环境:</strong> <%= isProduction ? 'production' : 'development' %></div>
      </div>
      <% } %>
      <div class="dev-section">
        <div class="dev-section-title">快捷操作</div>
        <a href="/admin" class="dev-btn">📊 管理后台</a>
        <a href="/logout" class="dev-btn">🔓 退出登录</a>
      </div>
    </div>
  </div>
  <script>
    function toggleDevModal() { document.getElementById('devModal').classList.toggle('show'); }
    document.addEventListener('click', function(e) {
      const m = document.getElementById('devModal'), b = document.querySelector('.dev-tool-btn');
      if (m && b && !m.contains(e.target) && !b.contains(e.target)) m.classList.remove('show');
    });
  </script>
  <% } %>
</body>
</html>