<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">心有所<span>SHU</span></a>
    <div class="nav-links">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile">我的资料</a>
        <a href="/matches">匹配结果</a>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <a href="/admin">管理</a>
        <% } %>
        <a href="/logout" class="btn">退出</a>
      <% } else { %>
        <a href="/login">登录</a>
      <% } %>
    </div>
  </div>
</nav>

<div class="hero">
  <h1>💕 心有所SHU</h1>
  <p>上海大学校园交友匹配系统</p>
  <p>每周为你推荐一位可能聊得来的同学</p>

  <p>当前为小范围测试，仅限内部使用</p>

  <% if (!user) { %>
    <a href="/register" class="btn" style="background: white; color: #e74c3c;">立即注册</a>
  <% } %>
</div>

<div class="features">
  <div class="feature-card">
    <div class="icon">📧</div>
    <h3>校园邮箱验证</h3>
    <p>仅限 @shu.edu.cn 邮箱，确保都是本校同学</p>
  </div>
  <div class="feature-card">
    <div class="icon">📝</div>
    <h3>简单问卷</h3>
    <p>填写你的专业、爱好、性格标签</p>
  </div>
  <div class="feature-card">
    <div class="icon">💌</div>
    <h3>每周匹配</h3>
    <p>系统每周为你推荐一位新朋友</p>
  </div>
</div>

<% if (user) { %>
<div class="card" style="margin-top: 30px;">
  <h2>欢迎回来，<%= user.name || user.email %>！</h2>
  <% if (!user.verified) { %>
    <div class="alert alert-error">
      ⚠️ 你的邮箱还未验证，请查收验证邮件完成验证。
    </div>
  <% } else { %>
    <div class="alert alert-success">
      ✅ 邮箱已验证
    </div>
    <% if (user.hasProfile) { %>
      <p>你的资料已完善，可以等待每周的匹配结果啦！</p>
      <a href="/matches" class="btn">查看匹配结果</a>
    <% } else { %>
      <p>还没有填写个人资料，快去完善吧～</p>
      <a href="/profile" class="btn">填写资料</a>
    <% } %>
  <% } %>
</div>
<% } %>

<footer class="footer">
  <p>© 2026 心有所SHU - 上海大学校园交友匹配系统</p>
</footer>