<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>心有所SHU - 上大交友匹配</title>
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <link rel="stylesheet" href="/css/dev-tools.css">
  <% } %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= messageType || 'info' %>"><%= message %></div>
    <% } %>

    <div class="hero">
      <h1>心有所SHU</h1>
      <p class="subtitle">上大同学之间的互相认识，从这里开始</p>
      <p style="opacity: 0.7; font-size: 0.9rem;">小范围内测中</p>
      <% if (typeof user === 'undefined' || !user) { %>
        <a href="/login" class="btn btn-large" style="background: white; color: var(--primary); margin-top: 20px;">开始</a>
      <% } %>
    </div>

    <div class="features">
      <div class="feature-card">
        <div class="icon">📧</div>
        <h3>学校邮箱</h3>
        <p>@shu.edu.cn 验证身份</p>
      </div>
      <div class="feature-card">
        <div class="icon">✏️</div>
        <h3>填个问卷</h3>
        <p>说说你的性格和爱好</p>
      </div>
      <div class="feature-card">
        <div class="icon">💕</div>
        <h3>每周推荐</h3>
        <p>认识一个可能聊得来的人</p>
      </div>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
    <div class="card">
      <h3 style="margin-bottom: 12px;">Hi, <%= user.name || user.email.split('@')[0] %></h3>
      <% if (!user.verified) { %>
        <div class="alert alert-warning" style="margin-bottom: 16px;">
          邮箱还没验证，去邮箱里点一下验证链接
        </div>
      <% } else { %>
        <% if (user.hasProfile) { %>
          <p style="color: var(--muted-foreground); margin-bottom: 16px;">资料填好了，等匹配结果吧</p>
          <a href="/matches" class="btn">看看匹配</a>
        <% } else { %>
          <p style="color: var(--muted-foreground); margin-bottom: 16px;">还差个问卷没填</p>
          <a href="/profile" class="btn">去填</a>
        <% } %>
      <% } %>
    </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>

  <%- include('partials/dev-tools', { isDev: typeof isDev !== 'undefined' ? isDev : false, port: typeof port !== 'undefined' ? port : '3000' }) %>
</body>
</html>