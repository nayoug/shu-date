<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('partials/document-head', { fullTitle: '心有所SHU - 上大交友匹配', devToolsStyles: true }) %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= messageType || 'info' %>"><%= message %></div>
    <% } %>

    <div class="hero">
      <h1>心有所SHU</h1>
      <p class="subtitle">上大同学之间的互相认识，从这里开始</p>
      <p style="opacity: 0.7; font-size: 0.9rem;">小范围内测中</p>
      <% if (typeof nextMatchTime !== 'undefined' && typeof now !== 'undefined') { %>
        <% const timeLeft = nextMatchTime - now; %>
        <% const days = Math.floor(timeLeft / (1000 * 60 * 60 * 24)); %>
        <% const hours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)); %>
        <% const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60)); %>
        <div class="countdown">
          <span class="countdown__label">距离下周二 19:00</span>
          <span class="countdown__time">
            <% if (days > 0) { %><%= days %>天 <% } %><%= hours %>小时 <%= minutes %>分钟
          </span>
        </div>
      <% } %>
      <% if (typeof user === 'undefined' || !user) { %>
        <a href="/login" class="btn btn-large" style="margin-top: 20px;">开始</a>
      <% } %>
    </div>

    <div class="features">
      <div class="feature-card">
        <div class="icon">📧</div>
        <h3>学校邮箱</h3>
        <p>@shu.edu.cn 验证身份</p>
      </div>
      <div class="feature-card">
        <div class="icon">✏️</div>
        <h3>填个问卷</h3>
        <p>说说你的性格和爱好</p>
      </div>
      <div class="feature-card">
        <div class="icon">💕</div>
        <h3>每周推荐</h3>
        <p>认识一个可能聊得来的人</p>
      </div>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
    <% const displayName = user.nickname || user.name || user.email.split('@')[0]; %>
    <section class="card home-status" aria-label="首页状态">
      <div class="home-status__main">
        <p class="home-status__eyebrow">欢迎回来</p>
        <h2 class="home-status__title"><%= displayName %></h2>
        <p class="home-status__identity"><%= user.email %></p>

        <% if (!user.verified) { %>
          <div class="alert alert-warning home-status__alert">
            邮箱还没验证，去邮箱里点一下验证链接
          </div>
          <p class="home-status__summary">先完成学校邮箱验证，后面的问卷和每周推荐才会解锁。</p>
          <div class="home-status__actions">
            <a href="/login" class="btn">回到登录页</a>
          </div>
        <% } else if (user.hasProfile) { %>
          <p class="home-status__summary">资料已经提交完成<% if (typeof weeklyMatchEnabled !== 'undefined' && weeklyMatchEnabled) { %>，接下来等每周推荐更新，再回来看看这周系统给你的结果。<% } else { %>。<% } %></p>
          <div class="home-status__actions">
<% if (typeof weeklyMatchEnabled !== 'undefined' && weeklyMatchEnabled) { %>
              <% if (user.weeklyMatchConfirmed) { %>
              <a href="/matches" class="btn">看看匹配</a>
              <a href="/confirm-match" class="btn btn-secondary">取消确认</a>
              <% } else { %>
              <a href="/confirm-match" class="btn">确认匹配</a>
              <% } %>
            <% } else { %>
              <% if (user.weeklyMatchConfirmed) { %>
              <a href="/matches" class="btn">看看匹配</a>
              <% } else { %>
              <a href="/confirm-match" class="btn">确认匹配</a>
              <% } %>
            <% } %>
            <a href="/profile?edit=1" class="btn btn-secondary">查看资料</a>
          </div>
        <% } else { %>
          <p class="home-status__summary">账号已经准备好，还差一份问卷。填完后系统才知道你想认识什么样的人。</p>
          <div class="home-status__actions">
            <a href="/profile" class="btn">去填问卷</a>
            <a href="/guide" class="btn btn-secondary">先看说明</a>
          </div>
        <% } %>
      </div>

      <aside class="home-status__aside" aria-label="当前进度">
        <p class="home-status__aside-title">当前进度</p>
        <ul class="home-status__steps">
          <li class="home-status__step <%= user.verified ? 'is-done' : 'is-current' %>">
            <span class="home-status__step-badge"><%= user.verified ? '✓' : '1' %></span>
            <div>
              <strong>学校邮箱验证</strong>
              <p><%= user.verified ? '已完成身份验证，可以继续下一步。' : '先去邮箱里点一下验证链接。' %></p>
            </div>
          </li>
          <li class="home-status__step <%= user.verified && user.hasProfile ? 'is-done' : (user.verified ? 'is-current' : 'is-pending') %>">
            <span class="home-status__step-badge"><%= user.verified && user.hasProfile ? '✓' : '2' %></span>
            <div>
              <strong>填写问卷</strong>
              <p><%= user.hasProfile ? '资料已经提交，偏好和性格信息都在库里。' : '补完资料后，系统才会进入匹配流程。' %></p>
            </div>
          </li>
          <% if (typeof weeklyMatchEnabled !== 'undefined' && weeklyMatchEnabled) { %>
          <li class="home-status__step <%= user.verified && user.hasProfile && user.weeklyMatchConfirmed ? 'is-done' : (user.verified && user.hasProfile ? 'is-current' : 'is-pending') %>">
            <span class="home-status__step-badge"><%= user.verified && user.hasProfile && user.weeklyMatchConfirmed ? '✓' : '3' %></span>
            <div>
              <strong>确认匹配</strong>
              <p><%= user.weeklyMatchConfirmed ? '已确认参与本周匹配。' : '在此处点击确认，是否确定参见本周匹配？' %></p>
            </div>
          </li>
          <li class="home-status__step <%= user.verified && user.hasProfile && user.weeklyMatchConfirmed ? 'is-current' : 'is-pending' %>">
            <span class="home-status__step-badge">4</span>
            <div>
              <strong>查看每周推荐</strong>
              <p><%= user.verified && user.hasProfile && user.weeklyMatchConfirmed ? '接下来只要等每周推荐更新，就可以回来看结果。' : '完成前两步后，这里会成为你的主要入口。' %></p>
            </div>
          </li>
          <% } else { %>
          <li class="home-status__step <%= user.verified && user.hasProfile ? 'is-current' : 'is-pending' %>">
            <span class="home-status__step-badge">3</span>
            <div>
              <strong>等待开启</strong>
              <p>每周匹配功能正在准备中，即将开放。</p>
            </div>
          </li>
          <% } %>
        </ul>
      </aside>
    </section>
    <% } %>
  </div>

  <%- include('partials/site-footer') %>

  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <%- include('partials/dev-tools') %>
  <% } %>
</body>
</html>
