<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/head-icons') %>
  <style>
    .login-tabs {
      display: flex;
      margin-bottom: 24px;
      border-bottom: 1px solid var(--border);
    }
    .login-tab {
      flex: 1;
      padding: 12px;
      text-align: center;
      cursor: pointer;
      color: var(--muted-foreground);
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
    }
    .login-tab.active {
      color: var(--primary);
      border-bottom-color: var(--primary);
      font-weight: 500;
    }
    .login-form {
      display: none;
    }
    .login-form.active {
      display: block;
    }
    .forgot-password {
      display: block;
      text-align: center;
      margin-top: 12px;
      color: var(--muted-foreground);
      font-size: 0.85rem;
      text-decoration: none;
    }
    .forgot-password:hover {
      color: var(--primary);
    }
    .inline-error {
      color: var(--error);
      font-size: 0.85rem;
      margin-top: -12px;
      margin-bottom: 12px;
      display: none;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container" style="max-width: 400px; padding-top: 80px;">
    <div class="card">
      <h2 style="text-align: center; margin-bottom: 6px;">嘿，同学</h2>
      <p style="text-align: center; color: var(--muted-foreground); font-size: 0.9rem; margin-bottom: 28px;">
        用学校邮箱登录就好
      </p>

      <% var loginMethod = loginMethod || 'login'; %>
      <% var error = error || ''; %>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-<%= messageType || 'info' %>">
          <%- message %>
        </div>
      <% } %>

      <% if (typeof debugLoginUrl !== 'undefined' && debugLoginUrl) { %>
        <div style="margin-top: 16px; text-align: center;">
          <a href="<%= debugLoginUrl %>" class="btn" style="background: var(--primary); color: white;">
            🔧 开发模式：点击直接登录
          </a>
        </div>
      <% } %>

      <!-- 登录方式切换 -->
      <div class="login-tabs">
        <div class="login-tab <%= (loginMethod === 'register') ? 'active' : '' %>" onclick="switchLoginMethod(event, 'register')">注册</div>
        <div class="login-tab <%= (loginMethod === 'login') ? 'active' : '' %>" onclick="switchLoginMethod(event, 'login')">登录</div>
      </div>

      <!-- 注册表单 -->
      <form action="/register" method="POST" class="login-form <%= (loginMethod === 'register') ? 'active' : '' %>">
        <div class="form-group">
          <input type="text" name="nickname" placeholder="昵称" autocomplete="nickname" aria-label="昵称" required style="text-align: center; font-size: 16px;">
        </div>
        <div class="form-group email-prefix-group">
          <input type="text" name="emailPrefix" placeholder="学号/邮箱前缀" autocomplete="email" aria-label="学校邮箱" autocapitalize="none" autocorrect="off" required style="text-align: center; font-size: 16px;">
          <span class="email-suffix">@shu.edu.cn</span>
        </div>
        <p class="inline-error" id="registerError">请输入有效的邮箱前缀</p>
        <input type="hidden" name="email" id="registerEmail">
        <div class="form-group">
          <input type="password" name="password" placeholder="设置密码（至少6位）" autocomplete="new-password" aria-label="设置密码" required minlength="6" style="text-align: center; font-size: 16px;">
        </div>
        <button type="submit" class="btn" style="width: 100%;">注册</button>
      </form>

      <!-- 登录表单 -->
      <form action="/login" method="POST" class="login-form <%= (loginMethod === 'login') ? 'active' : '' %>">
        <div class="form-group email-prefix-group">
          <input type="text" name="emailPrefix" placeholder="学号/邮箱前缀" value="<%= typeof email !== 'undefined' && email ? email.split('@')[0] : '' %>" autocomplete="username" aria-label="登录邮箱" autocapitalize="none" autocorrect="off" required style="text-align: center; font-size: 16px;">
          <span class="email-suffix">@shu.edu.cn</span>
        </div>
        <p class="inline-error" id="loginError">请输入有效的邮箱前缀</p>
        <input type="hidden" name="email" id="loginEmail">
        <div class="form-group">
          <input type="password" name="password" placeholder="登录密码" autocomplete="current-password" aria-label="登录密码" required style="text-align: center; font-size: 16px;">
        </div>
        <button type="submit" class="btn" style="width: 100%;">登录</button>
        <a href="/forgot" class="forgot-password">忘记密码？</a>
      </form>

      <p style="text-align: center; color: var(--muted-foreground); font-size: 0.8rem; margin-top: 24px;">
        仅支持 @shu.edu.cn 邮箱
      </p>
    </div>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>

  <script>
    function switchLoginMethod(evt, method) {
      // 更新 tab 状态
      document.querySelectorAll('.login-tab').forEach(tab => {
        tab.classList.remove('active');
      });
      evt.target.classList.add('active');

      // 更新表单显示
      document.querySelectorAll('.login-form').forEach(form => {
        form.classList.remove('active');
      });

      if (method === 'register') {
        document.querySelector('form[action="/register"]').classList.add('active');
      } else {
        document.querySelector('form[action="/login"]').classList.add('active');
      }
    }

    // 表单提交前拼接完整邮箱
    function cleanPrefix(prefix) {
      prefix = prefix.trim();
      // 如果用户输入了完整邮箱，提取前缀
      if (prefix.includes('@')) {
        prefix = prefix.split('@')[0];
      }
      // 只保留合法字符
      prefix = prefix.replace(/[^a-zA-Z0-9._-]/g, '');
      return prefix;
    }

    document.querySelector('form[action="/register"]').addEventListener('submit', function(e) {
      const errorEl = document.getElementById('registerError');
      errorEl.style.display = 'none';
      const prefix = cleanPrefix(this.querySelector('input[name="emailPrefix"]').value);
      if (!prefix) {
        e.preventDefault();
        errorEl.style.display = 'block';
        return;
      }
      this.querySelector('#registerEmail').value = prefix + '@shu.edu.cn';
    });

    document.querySelector('form[action="/login"]').addEventListener('submit', function(e) {
      const errorEl = document.getElementById('loginError');
      errorEl.style.display = 'none';
      const prefix = cleanPrefix(this.querySelector('input[name="emailPrefix"]').value);
      if (!prefix) {
        e.preventDefault();
        errorEl.style.display = 'block';
        return;
      }
      this.querySelector('#loginEmail').value = prefix + '@shu.edu.cn';
    });

    // 输入时隐藏错误提示
    document.querySelectorAll('input[name="emailPrefix"]').forEach(input => {
      input.addEventListener('input', function() {
        document.querySelectorAll('.inline-error').forEach(el => el.style.display = 'none');
      });
    });
  </script>
</body>
</html>
