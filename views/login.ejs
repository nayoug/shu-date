<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">心有所<span>SHU</span></a>
    </div>
  </nav>

  <div class="container" style="max-width: 400px; padding-top: 80px;">
    <div class="card">
    <h2 style="text-align: center; margin-bottom: 6px;">嘿，同学</h2>
    <p style="text-align: center; color: var(--muted-foreground); font-size: 0.9rem; margin-bottom: 28px;">
          用学校邮箱登录就好
    </p>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= messageType || 'info' %>">
        <%- message %>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <input type="email" name="email" placeholder="你的学校邮箱" value="<%= typeof email !== 'undefined' ? email : '' %>" required style="text-align: center; font-size: 16px;">
      </div>
      <button type="submit" class="btn" style="width: 100%;">发送登录链接</button>
    </form>

    <p style="text-align: center; color: var(--muted-foreground); font-size: 0.8rem; margin-top: 24px;">
      仅支持 @shu.edu.cn 邮箱
    </p>
  </div>
</div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>
</body>
</html>
