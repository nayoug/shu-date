<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <style>
    .dev-tool-btn {
      position: fixed;
      top: 15px;
      right: 15px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      cursor: pointer;
      font-size: 16px;
      box-shadow: 0 2px 10px rgba(102, 126, 234, 0.4);
      z-index: 9999;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .dev-tool-btn:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.6);
    }
    .dev-modal {
      display: none;
      position: fixed;
      top: 60px;
      right: 15px;
      width: 300px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      z-index: 9998;
      overflow: hidden;
    }
    .dev-modal.show {
      display: block;
      animation: slideDown 0.2s ease;
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .dev-modal-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 12px 16px;
      font-weight: bold;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .dev-modal-header .close-btn {
      background: none;
      border: none;
      color: white;
      font-size: 18px;
      cursor: pointer;
      opacity: 0.8;
    }
    .dev-modal-header .close-btn:hover {
      opacity: 1;
    }
    .dev-modal-body {
      padding: 16px;
    }
    .dev-section {
      margin-bottom: 16px;
    }
    .dev-section:last-child {
      margin-bottom: 0;
    }
    .dev-section-title {
      font-size: 12px;
      color: #888;
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    .dev-btn {
      display: block;
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 8px;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      background: #f8f9fa;
      color: #333;
      text-decoration: none;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
    }
    .dev-btn:last-child {
      margin-bottom: 0;
    }
    .dev-btn:hover {
      background: #667eea;
      color: white;
      border-color: #667eea;
    }
    .dev-btn.primary {
      background: #667eea;
      color: white;
      border-color: #667eea;
    }
    .dev-btn.primary:hover {
      background: #764ba2;
      border-color: #764ba2;
    }
    .dev-info {
      font-size: 12px;
      color: #666;
      background: #f0f0f0;
      padding: 8px 10px;
      border-radius: 6px;
      margin-bottom: 8px;
    }
    .dev-badge {
      display: inline-block;
      background: #4caf50;
      color: white;
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 10px;
      margin-left: 8px;
    }
  </style>
  <% } %>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">心有所<span>SHU</span></a>
    </div>
  </nav>

  <div class="container" style="max-width: 400px; padding-top: 80px;">
    <div class="card">
    <h2 style="text-align: center; margin-bottom: 6px;">嘿，同学</h2>
    <p style="text-align: center; color: var(--muted-foreground); font-size: 0.9rem; margin-bottom: 28px;">
          用学校邮箱登录就好
    </p>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= messageType || 'info' %>">
        <%- message %>
      </div>
    <% } %>

    <form action="/login" method="POST" onsubmit="return handleSubmit(event)">
      <div class="form-group">
        <div style="display: flex; align-items: center; gap: 0;">
          <input type="text" id="emailPrefix" placeholder="你的学号/工号" value="<%= typeof email !== 'undefined' && email ? email.replace('@shu.edu.cn', '') : '' %>" required style="flex: 1; text-align: center; font-size: 16px; border-radius: 6px 0 0 6px; border-right: none;">
          <span style="background: #f0f0f0; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 0 6px 6px 0; color: #666; font-size: 14px; white-space: nowrap;">@shu.edu.cn</span>
        </div>
        <input type="hidden" name="email" id="emailFull">
      </div>
      <button type="submit" class="btn" style="width: 100%;">发送登录链接</button>
    </form>

    <script>
    function handleSubmit(e) {
      const prefix = document.getElementById('emailPrefix').value.trim();
      if (!prefix) {
        alert('请输入学号/工号');
        return false;
      }
      document.getElementById('emailFull').value = prefix + '@shu.edu.cn';
      return true;
    }
    </script>
  </div>
</div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>

  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <!-- 开发者工具按钮 -->
  <button class="dev-tool-btn" onclick="toggleDevModal()" title="开发者工具">🔧</button>

  <!-- 开发者工具弹窗 -->
  <div class="dev-modal" id="devModal">
    <div class="dev-modal-header">
      <span>🛠️ 开发者工具<span class="dev-badge">DEV</span></span>
      <button class="close-btn" onclick="toggleDevModal()">×</button>
    </div>
    <div class="dev-modal-body">
      <div class="dev-section">
        <div class="dev-section-title">快速登录</div>
        <a href="/login/verify/abc123456" class="dev-btn primary">🚀 测试用户一键登录</a>
      </div>
      <div class="dev-section">
        <div class="dev-section-title">环境信息</div>
        <div class="dev-info">
          <strong>环境:</strong> development<br>
          <strong>端口:</strong> <%= typeof port !== 'undefined' ? port : '3000' %>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleDevModal() {
      const modal = document.getElementById('devModal');
      modal.classList.toggle('show');
    }
    document.addEventListener('click', function(e) {
      const modal = document.getElementById('devModal');
      const btn = document.querySelector('.dev-tool-btn');
      if (modal && btn && !modal.contains(e.target) && !btn.contains(e.target)) {
        modal.classList.remove('show');
      }
    });
  </script>
  <% } %>
</body>
</html>
