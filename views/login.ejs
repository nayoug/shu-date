<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/head-icons') %>
  <style>
    .login-tabs {
      display: flex;
      margin-bottom: 24px;
      border-bottom: 1px solid var(--border);
    }
    .login-tab {
      flex: 1;
      padding: 12px;
      text-align: center;
      cursor: pointer;
      color: var(--muted-foreground);
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
    }
    .login-tab.active {
      color: var(--primary);
      border-bottom-color: var(--primary);
      font-weight: 500;
    }
    .login-form {
      display: none;
    }
    .login-form.active {
      display: block;
    }
    .forgot-password {
      display: block;
      text-align: center;
      margin-top: 12px;
      color: var(--muted-foreground);
      font-size: 0.85rem;
      text-decoration: none;
    }
    .forgot-password:hover {
      color: var(--primary);
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container" style="max-width: 400px; padding-top: 80px;">
    <div class="card">
      <h2 style="text-align: center; margin-bottom: 6px;">嘿，同学</h2>
      <p style="text-align: center; color: var(--muted-foreground); font-size: 0.9rem; margin-bottom: 28px;">
        用学校邮箱登录就好
      </p>

      <% var loginMethod = loginMethod || 'login'; %>
      <% var error = error || ''; %>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-<%= messageType || 'info' %>">
          <%- message %>
        </div>
      <% } %>

      <% if (typeof debugLoginUrl !== 'undefined' && debugLoginUrl) { %>
        <div style="margin-top: 16px; text-align: center;">
          <a href="<%= debugLoginUrl %>" class="btn" style="background: var(--primary); color: white;">
            🔧 开发模式：点击直接登录
          </a>
        </div>
      <% } %>

      <!-- 登录方式切换 -->
      <div class="login-tabs">
        <div class="login-tab <%= (loginMethod === 'register') ? 'active' : '' %>" onclick="switchLoginMethod('register')">注册</div>
        <div class="login-tab <%= (loginMethod === 'login') ? 'active' : '' %>" onclick="switchLoginMethod('login')">登录</div>
      </div>

      <!-- 注册表单 -->
      <form action="/register" method="POST" class="login-form <%= (loginMethod === 'register') ? 'active' : '' %>" onsubmit="return handleRegisterSubmit(event)">
        <div class="form-group">
          <input type="text" name="nickname" placeholder="昵称" autocomplete="nickname" aria-label="昵称" required style="text-align: center; font-size: 16px;">
        </div>
        <div class="form-group">
          <div style="display: flex; align-items: center; gap: 0;">
            <input type="text" id="registerEmailPrefix" placeholder="请输入学校邮箱" value="<%= typeof email !== 'undefined' && email ? email.replace('@shu.edu.cn', '') : '' %>" required style="flex: 1; text-align: center; font-size: 16px; border-radius: 6px 0 0 6px; border-right: none;">
            <span style="background: #f0f0f0; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 0 6px 6px 0; color: #666; font-size: 14px; white-space: nowrap;">@shu.edu.cn</span>
          </div>
          <input type="hidden" name="email" id="registerEmailFull">
        </div>
        <div class="form-group">
          <input type="password" name="password" placeholder="设置密码（至少6位）" autocomplete="new-password" aria-label="设置密码" required minlength="6" style="text-align: center; font-size: 16px;">
        </div>
        <button type="submit" class="btn" style="width: 100%;">注册</button>
      </form>

      <!-- 登录表单 -->
      <form action="/login" method="POST" class="login-form <%= (loginMethod === 'login') ? 'active' : '' %>" onsubmit="return handleLoginSubmit(event)">
        <div class="form-group">
          <div style="display: flex; align-items: center; gap: 0;">
            <input type="text" id="loginEmailPrefix" placeholder="请输入学校邮箱" value="<%= typeof email !== 'undefined' && email ? email.replace('@shu.edu.cn', '') : '' %>" required style="flex: 1; text-align: center; font-size: 16px; border-radius: 6px 0 0 6px; border-right: none;">
            <span style="background: #f0f0f0; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 0 6px 6px 0; color: #666; font-size: 14px; white-space: nowrap;">@shu.edu.cn</span>
          </div>
          <input type="hidden" name="email" id="loginEmailFull">
        </div>
        <div class="form-group">
          <input type="password" name="password" placeholder="登录密码" autocomplete="current-password" aria-label="登录密码" required style="text-align: center; font-size: 16px;">
        </div>
        <button type="submit" class="btn" style="width: 100%;">登录</button>
        <a href="/forgot" class="forgot-password">忘记密码？</a>
      </form>

      <p style="text-align: center; color: var(--muted-foreground); font-size: 0.8rem; margin-top: 24px;">
        仅支持 @shu.edu.cn 邮箱
      </p>
    </div>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU</p>
  </footer>

  <script>
    function switchLoginMethod(method) {
      // 更新 tab 状态
      document.querySelectorAll('.login-tab').forEach(tab => {
        tab.classList.remove('active');
      });
      event.target.classList.add('active');

      // 更新表单显示
      document.querySelectorAll('.login-form').forEach(form => {
        form.classList.remove('active');
      });

      if (method === 'register') {
        document.querySelector('form[action="/register"]').classList.add('active');
      } else {
        document.querySelector('form[action="/login"]').classList.add('active');
      }
    }

    function handleRegisterSubmit(e) {
      const prefix = document.getElementById('registerEmailPrefix').value.trim();
      if (!prefix) {
        alert('请输入学校邮箱');
        return false;
      }
      document.getElementById('registerEmailFull').value = prefix + '@shu.edu.cn';
      return true;
    }

    function handleLoginSubmit(e) {
      const prefix = document.getElementById('loginEmailPrefix').value.trim();
      if (!prefix) {
        alert('请输入学校邮箱');
        return false;
      }
      document.getElementById('loginEmailFull').value = prefix + '@shu.edu.cn';
      return true;
    }
  </script>
</body>
</html>
