<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('partials/document-head', { pageTitle: '匹配结果', devToolsStyles: true }) %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (!user.verified) { %>
    <div class="card" style="text-align: center;">
      <div style="font-size: 4rem; margin-bottom: 16px;">⚠️</div>
      <h2>邮箱未验证</h2>
      <p style="color: var(--muted-foreground);">请先完成邮箱验证后查看匹配结果。</p>
    </div>
    <% } else if (!matches || matches.length === 0) { %>
    <div class="card" style="text-align: center;">
      <div style="font-size: 4rem; margin-bottom: 16px;">🤔</div>
      <h2><%= hasWeeklyRelease ? '本周暂未匹配成功' : '本周匹配尚未发布' %></h2>
      <p style="color: var(--muted-foreground); margin-bottom: 24px;">
        <%= hasWeeklyRelease
          ? '本周正式匹配结果已经发布，但这周暂时还没有匹配到适合你的对象。'
          : '本周正式匹配结果还没发布，等管理员执行本周匹配后再来看看。' %>
      </p>
    </div>
    <% } else { %>
    <div class="card">
      <h2 style="display: flex; align-items: center; gap: 10px;">
        💕 本周正式匹配结果
      </h2>
      <p style="color: var(--muted-foreground); margin-bottom: 24px;">
        这是本周已经发布并落库的正式匹配结果：
      </p>

      <div class="match-list">
        <% matches.forEach(function(m, index) { %>
        <div class="match-card">
          <div class="match-rank">
            #<%= index + 1 %>
          </div>
          <div class="match-summary">
            <div class="match-meta">
              <span><strong>年级:</strong> <%= m.my_grade || '-' %></span>
              <span><strong>性别:</strong> <%= m.gender || '-' %></span>
              <span><strong>校区:</strong> <%= m.campus || '-' %></span>
              <span><strong>LoveType:</strong> <%= m.lovetype_code || '-' %></span>
            </div>
            <div class="match-interest">
              <strong>兴趣爱好:</strong> <%= m.interests || '-' %>
            </div>
          </div>
          <% if (m.score !== null && m.score !== undefined) { %>
          <% const scoreTone = m.score >= 0.7 ? 'high' : (m.score >= 0.5 ? 'medium' : 'low'); %>
          <div class="match-score match-score--<%= scoreTone %>">
            <%= Math.round(m.score * 100) %>%
          </div>
          <% } %>
        </div>
        <% }); %>
      </div>

      <% if (matches.some(function(m) { return m.score !== null && m.score !== undefined; })) { %>
      <p style="margin-top: 24px; color: var(--muted-foreground); font-size: 0.85rem; text-align: center;">
        💡 匹配度算法：综合考虑兴趣爱好、生活习惯和恋爱观念，并结合 LoveType 兼容性做加减分
      </p>
      <% } %>
    </div>
    <% } %>
  </div>

  <%- include('partials/site-footer') %>

  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <%- include('partials/dev-tools') %>
  <% } %>
</body>
</html>
