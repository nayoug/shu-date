<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>匹配结果 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (!user.verified) { %>
    <div class="card" style="text-align: center;">
      <div style="font-size: 4rem; margin-bottom: 16px;">⚠️</div>
      <h2>邮箱未验证</h2>
      <p style="color: var(--muted-foreground);">请先完成邮箱验证后查看匹配结果。</p>
    </div>
    <% } else if (!matches || matches.length === 0) { %>
    <div class="card" style="text-align: center;">
      <div style="font-size: 4rem; margin-bottom: 16px;">🤔</div>
      <h2>暂无匹配</h2>
      <p style="color: var(--muted-foreground); margin-bottom: 24px;">
        内测阶段暂不支持匹配功能。
      </p>
    </div>
    <% } else { %>
    <div class="card">
      <h2 style="display: flex; align-items: center; gap: 10px;">
        💕 匹配结果
      </h2>
      <p style="color: var(--muted-foreground); margin-bottom: 24px;">
        根据你的问卷，为你推荐以下同学：
      </p>

      <div style="display: grid; gap: 16px;">
        <% matches.forEach(function(m, index) { %>
        <div class="match-card" style="display: flex; align-items: center; gap: 20px; padding: 20px;">
          <div style="font-size: 2rem; font-weight: 700; color: var(--primary); min-width: 50px;">
            #<%= index + 1 %>
          </div>
          <div style="flex: 1;">
            <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 8px;">
              <span><strong>年级:</strong> <%= m.my_grade || '-' %></span>
              <span><strong>性别:</strong> <%= m.gender || '-' %></span>
              <span><strong>校区:</strong> <%= m.campus || '-' %></span>
              <span><strong>LoveType:</strong> <%= m.lovetype_code || '-' %></span>
            </div>
            <div style="color: var(--muted-foreground); font-size: 0.9rem;">
              <strong>兴趣爱好:</strong> <%= m.interests || '-' %>
            </div>
          </div>
          <div class="match-score" style="
            background: <%= m.score >= 0.7 ? 'oklch(0.95 0.08 145)' : m.score >= 0.5 ? 'oklch(0.95 0.08 80)' : 'oklch(0.95 0.08 25)' %>;
            color: <%= m.score >= 0.7 ? 'oklch(0.4 0.12 145)' : m.score >= 0.5 ? 'oklch(0.45 0.12 80)' : 'oklch(0.45 0.15 25)' %>;
          ">
            <%= Math.round(m.score * 100) %>%
          </div>
        </div>
        <% }); %>
      </div>

      <p style="margin-top: 24px; color: var(--muted-foreground); font-size: 0.85rem; text-align: center;">
        💡 匹配度算法：兴趣爱好30% + 生活习惯30% + 恋爱观念40%，再结合 LoveType 兼容性做加减分
      </p>
    </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>© 2026 心有所SHU - 上海大学校园交友匹配系统</p>
  </footer>

  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <style>
    .dev-tool-btn {
      position: fixed;
      top: 15px;
      right: 15px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      cursor: pointer;
      font-size: 16px;
      box-shadow: 0 2px 10px rgba(102, 126, 234, 0.4);
      z-index: 9999;
    }
    .dev-tool-btn:hover { transform: scale(1.1); }
    .dev-modal {
      display: none;
      position: fixed;
      top: 60px;
      right: 15px;
      width: 300px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      z-index: 9998;
      overflow: hidden;
    }
    .dev-modal.show { display: block; }
    .dev-modal-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 12px 16px;
      font-weight: bold;
      display: flex;
      justify-content: space-between;
    }
    .dev-modal-header .close-btn {
      background: none;
      border: none;
      color: white;
      font-size: 18px;
      cursor: pointer;
    }
    .dev-modal-body { padding: 16px; }
    .dev-section { margin-bottom: 16px; }
    .dev-section:last-child { margin-bottom: 0; }
    .dev-section-title { font-size: 12px; color: #888; margin-bottom: 8px; }
    .dev-btn {
      display: block;
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 8px;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      background: #f8f9fa;
      color: #333;
      text-decoration: none;
      text-align: center;
    }
    .dev-btn:hover { background: #667eea; color: white; border-color: #667eea; }
    .dev-btn.primary { background: #667eea; color: white; border-color: #667eea; }
    .dev-info { font-size: 12px; color: #666; background: #f0f0f0; padding: 8px 10px; border-radius: 6px; }
    .dev-badge { background: #4caf50; color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px; margin-left: 8px; }
  </style>
  <button class="dev-tool-btn" onclick="toggleDevModal()">🔧</button>
  <div class="dev-modal" id="devModal">
    <div class="dev-modal-header">
      <span>🛠️ 开发者工具<span class="dev-badge">DEV</span></span>
      <button class="close-btn" onclick="toggleDevModal()">×</button>
    </div>
    <div class="dev-modal-body">
      <% if (typeof isDev !== 'undefined' && isDev) { %>
      <div class="dev-section">
        <div class="dev-section-title">环境信息</div>
        <div class="dev-info"><strong>环境:</strong> <%= isProduction ? 'production' : 'development' %></div>
      </div>
      <% } %>
      <div class="dev-section">
        <div class="dev-section-title">快捷操作</div>
        <a href="/admin" class="dev-btn">📊 管理后台</a>
        <a href="/logout" class="dev-btn">🔓 退出登录</a>
      </div>
    </div>
  </div>
  <script>
    function toggleDevModal() { document.getElementById('devModal').classList.toggle('show'); }
    document.addEventListener('click', function(e) {
      const m = document.getElementById('devModal'), b = document.querySelector('.dev-tool-btn');
      if (m && b && !m.contains(e.target) && !b.contains(e.target)) m.classList.remove('show');
    });
  </script>
  <% } %>
</body>
</html>
