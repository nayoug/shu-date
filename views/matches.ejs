  <script>
    // 加载实时推荐
    async function loadRecommendations() {
      const container = document.getElementById('recommendList');
      container.innerHTML = '<div class="loading"><div class="spinner"></div><p>正在计算最佳匹配...</p></div>';

      try {
        const response = await fetch('/api/match/top');
        const data = await response.json();

        if (data.success && data.data && data.data.length > 0) {
          container.innerHTML = data.data.map((m, i) => `
            <div class="recommend-card">
              <div class="card-header">
                <div class="rank">${i + 1}</div>
                <div class="mini-score">${Math.round(m.score * 100)}%</div>
              </div>
              <div class="info-row">
                <span>🎓 ${m.my_grade || '-'}</span>
                <span>👤 ${m.gender || '-'}</span>
                <span>📍 ${m.campus || '-'}</span>
              </div>
              ${m.lovetype_code ? `<div class="lovetype-mini">${m.lovetype_code}</div>` : ''}
              ${m.interests ? `
                <div style="margin-top: 10px;">
                  ${m.interests.split(',').slice(0, 3).map(tag =>
                    `<span class="interest-tag" style="font-size: 0.75rem; padding: 4px 8px;">${tag.trim().replace(/^[^-]+-/, '')}</span>`
                  ).join('')}
                </div>
              ` : ''}
            </div>
          `).join('');
        } else {
          container.innerHTML = `
            <div class="card" style="grid-column: 1/-1; text-align: center; padding: 40px;">
              <p style="color: var(--muted-foreground);">暂无推荐数据，可能还没有足够的用户填写问卷</p>
            </div>
          `;
        }
      } catch (error) {
        container.innerHTML = `
          <div class="card" style="grid-column: 1/-1; text-align: center; padding: 40px;">
            <p style="color: var(--error);">加载失败，请稍后重试</p>
          </div>
        `;
      }
    }

    // 页面加载时自动获取推荐
    document.addEventListener('DOMContentLoaded', loadRecommendations);
  </script>

