<% if (!user.verified) { %>
<div class="card">
  <h2>⚠️ 邮箱未验证</h2>
  <p>请先完成邮箱验证。</p>
</div>
<% } else if (!matches || matches.length === 0) { %>
<div class="card" style="text-align: center;">
  <h2>🤔 暂无匹配</h2>
  <p>你还没有填写问卷，或者系统暂无匹配用户。</p>
  <a href="/profile" class="btn">填写问卷</a>
</div>
<% } else { %>
<div class="card">
  <h2>💕 匹配结果</h2>
  <p style="color: #666;">
    <%= matchSource === 'weekly' ? '这是系统为你锁定的本周匹配对象。' : '根据你的问卷，为你推荐以下同学：' %>
  </p>

  <table>
    <thead>
      <tr>
        <th>排名</th>
        <th>年级</th>
        <th>性别</th>
        <th>校区</th>
        <th>兴趣爱好</th>
        <th>匹配度</th>
      </tr>
    </thead>
    <tbody>
      <% matches.forEach(function(m, index) { %>
      <tr>
        <td>#<%= index + 1 %></td>
        <td><%= m.my_grade || '-' %></td>
        <td><%= m.gender || '-' %></td>
        <td><%= m.campus || '-' %></td>
        <td><%= m.interests || '-' %></td>
        <td>
          <span style="color: <%= m.score >= 0.7 ? '#27ae60' : m.score >= 0.5 ? '#f39c12' : '#e74c3c' %>; font-weight: bold;">
            <%= Math.round(m.score * 100) %>%
          </span>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <p style="margin-top: 20px; color: #666; font-size: 14px;">
    <% if (matchSource === 'weekly') { %>
      💡 当前优先展示的是本周已落库的匹配结果。
    <% } else { %>
      💡 匹配度算法：兴趣爱好30% + 生活习惯30% + 恋爱观念40%
    <% } %>
  </p>
</div>
<% } %>
