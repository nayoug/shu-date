<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>填写问卷 - 心有所SHU</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .option-group {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .option-group label {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .option-group label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .option-group label.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .option-group input[type="radio"] {
      width: auto;
      margin: 0;
    }

    /* Range slider styles */
    .range-container {
      padding: 10px 0;
    }
    .range-slider {
      width: 100%;
      margin: 10px 0;
    }
    .range-labels {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #666;
    }
    .range-value {
      text-align: center;
      font-weight: 600;
      color: #e74c3c;
      margin-top: 8px;
    }

    /* Multi-select checkbox group */
    .checkbox-group-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }
    .checkbox-group-grid label {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .checkbox-group-grid label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .checkbox-group-grid label.checked {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .checkbox-group-grid input[type="checkbox"] {
      width: auto;
      margin: 0;
    }

    /* Province select */
    .province-select {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      font-size: 14px;
    }

    /* 5-point scale for new questions */
    .scale-5 {
      display: flex;
      gap: 8px;
    }
    .scale-5 label {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 12px 8px;
      border-radius: 10px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      text-align: center;
      font-size: 13px;
      transition: all 0.2s;
    }
    .scale-5 label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .scale-5 label.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .scale-5 input[type="radio"] {
      width: auto;
      margin-bottom: 6px;
    }
    .scale-5 .scale-endpoints {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #888;
      margin-bottom: 8px;
    }

    /* Interest tags */
    .interest-category {
      margin-bottom: 16px;
    }
    .interest-category-title {
      font-weight: 600;
      color: #e74c3c;
      margin-bottom: 10px;
      font-size: 14px;
    }
    .interest-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .interest-tag {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 20px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .interest-tag:hover {
      border-color: #e74c3c;
    }
    .interest-tag.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .interest-tag input {
      display: none;
    }
    .interest-counter {
      font-size: 13px;
      color: #666;
      margin-bottom: 12px;
    }

    .form-section {
      border-bottom: 1px solid #eee;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }
    .checkbox-group label {
      display: inline-block;
      margin-right: 15px;
      margin-bottom: 8px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">心有所<span>SHU</span></a>
      <div class="nav-links">
        <a href="/profile" style="color: var(--primary); font-weight: 600;">资料</a>
        <a href="/matches">匹配</a>
        <a href="/logout" class="btn btn-secondary" style="padding: 6px 14px; font-size: 0.85rem;">退出</a>
      </div>
    </div>
  </nav>

  <div class="container" style="max-width: 800px;">
    <div class="card">
      <h2 style="margin-bottom: 8px;">📝 恋爱匹配问卷</h2>
      <p style="color: var(--muted-foreground); margin-bottom: 24px;">填完这个，我们就能帮你找到聊得来的人</p>

      <% if (typeof isDev !== 'undefined' && isDev) { %>
        <button type="button" id="devFillBtn" class="btn btn-secondary" style="margin-bottom: 20px;">🔧 一键填写（测试）</button>
      <% } %>

  <% if (lovetypeResult) { %>
    <div class="lovetype-result-card">
      <div class="lovetype-result-header">
        <span class="lovetype-badge"><%= lovetypeResult.code %></span>
        <div>
          <h3><%= lovetypeResult.title %></h3>
          <p>你的 Love Type16 当前结果</p>
        </div>
      </div>

      <% if (lovetypeAssessment && lovetypeAssessment.dimensions) { %>
        <div class="lovetype-dimensions">
          <% lovetypeAssessment.dimensions.forEach(function(dimension) { %>
            <div class="lovetype-dimension-chip">
              <strong><%= dimension.pair %></strong>
              <span><%= dimension.leftScore %> : <%= dimension.rightScore %></span>
            </div>
          <% }); %>
        </div>
      <% } %>

      <% if (lovetypeResult.intro && lovetypeResult.intro.length) { %>
        <div class="lovetype-copy-block">
          <h4>什么是<%= lovetypeResult.title %>?</h4>
          <% lovetypeResult.intro.forEach(function(paragraph) { %>
            <p><%= paragraph %></p>
          <% }); %>
        </div>
      <% } %>

      <% if (lovetypeResult.traits && lovetypeResult.traits.length) { %>
        <div class="lovetype-copy-block">
          <h4><%= lovetypeResult.title %>在爱情中的特征</h4>
          <% lovetypeResult.traits.forEach(function(paragraph) { %>
            <p><%= paragraph %></p>
          <% }); %>
        </div>
      <% } %>

      <div class="lovetype-copy-block">
        <h4>与其他人格类型的兼容性</h4>

        <% if (lovetypeResult.compatibilityTypes && lovetypeResult.compatibilityTypes.best && lovetypeResult.compatibilityTypes.best.length) { %>
          <h5>💖 最佳配对</h5>
          <div class="lovetype-type-list">
            <% lovetypeResult.compatibilityTypes.best.forEach(function(typeCode) { %>
              <span class="lovetype-type-pill"><%= typeCode %></span>
            <% }); %>
          </div>
        <% } %>

        <% if (lovetypeResult.compatibilityTypes && lovetypeResult.compatibilityTypes.good && lovetypeResult.compatibilityTypes.good.length) { %>
          <h5>👍 良好配对</h5>
          <div class="lovetype-type-list">
            <% lovetypeResult.compatibilityTypes.good.forEach(function(typeCode) { %>
              <span class="lovetype-type-pill"><%= typeCode %></span>
            <% }); %>
          </div>
        <% } %>

        <% if (lovetypeResult.compatibilityTypes && lovetypeResult.compatibilityTypes.challenge && lovetypeResult.compatibilityTypes.challenge.length) { %>
          <h5>🌀 需要磨合的配对</h5>
          <div class="lovetype-type-list">
            <% lovetypeResult.compatibilityTypes.challenge.forEach(function(typeCode) { %>
              <span class="lovetype-type-pill"><%= typeCode %></span>
            <% }); %>
          </div>
        <% } %>
      </div>

      <% if (lovetypeResult.conclusion && lovetypeResult.conclusion.length) { %>
        <div class="lovetype-copy-block">
          <h4>结论</h4>
          <% lovetypeResult.conclusion.forEach(function(paragraph) { %>
            <p><%= paragraph %></p>
          <% }); %>
        </div>
      <% } %>
    </div>
  <% } %>

  <form action="/survey/submit" method="POST">

    <!-- 一、基础信息 -->
    <div class="form-section">
      <h3 style="color: #e74c3c; margin: 20px 0 15px;">一、基础信息</h3>

      <div class="form-group">
        <label>1. 我的性别是：</label>
        <div class="option-group">
          <label><input type="radio" name="gender" value="男" <%= profile && profile.gender === '男' ? 'checked' : '' %> required> A. 男</label>
          <label><input type="radio" name="gender" value="女" <%= profile && profile.gender === '女' ? 'checked' : '' %>> B. 女</label>
        </div>
      </div>

      <div class="form-group">
        <label>2. 我的年龄是：</label>
        <div class="option-group">
          <label><input type="radio" name="age" value="18" <%= profile && profile.age === '18' ? 'checked' : '' %> required> A. 18岁</label>
          <label><input type="radio" name="age" value="19" <%= profile && profile.age === '19' ? 'checked' : '' %>> B. 19岁</label>
          <label><input type="radio" name="age" value="20" <%= profile && profile.age === '20' ? 'checked' : '' %>> C. 20岁</label>
          <label><input type="radio" name="age" value="21" <%= profile && profile.age === '21' ? 'checked' : '' %>> D. 21岁</label>
          <label><input type="radio" name="age" value="22" <%= profile && profile.age === '22' ? 'checked' : '' %>> E. 22岁</label>
          <label><input type="radio" name="age" value="23" <%= profile && profile.age === '23' ? 'checked' : '' %>> F. 23岁</label>
          <label><input type="radio" name="age" value="24" <%= profile && profile.age === '24' ? 'checked' : '' %>> G. 24岁</label>
          <label><input type="radio" name="age" value="25" <%= profile && profile.age === '25' ? 'checked' : '' %>> H. 25岁</label>
          <label><input type="radio" name="age" value="26" <%= profile && profile.age === '26' ? 'checked' : '' %>> I. 26岁及以上</label>
        </div>
      </div>

      <div class="form-group">
        <label>3. 我希望匹配的对象性别是：</label>
        <div class="option-group">
          <label><input type="radio" name="preferred_gender" value="男" <%= profile && profile.preferred_gender === '男' ? 'checked' : '' %> required> A. 男</label>
          <label><input type="radio" name="preferred_gender" value="女" <%= profile && profile.preferred_gender === '女' ? 'checked' : '' %>> B. 女</label>
          <label><input type="radio" name="preferred_gender" value="不限" <%= profile && profile.preferred_gender === '不限' ? 'checked' : '' %>> C. 不限</label>
        </div>
      </div>

      <div class="form-group">
        <label>4. 我来这里的首要目的是：</label>
        <div class="option-group">
          <label><input type="radio" name="purpose" value="寻找长期恋爱伴侣" <%= profile && profile.purpose === '寻找长期恋爱伴侣' ? 'checked' : '' %> required> A. 寻找长期恋爱伴侣</label>
          <label><input type="radio" name="purpose" value="寻找短期约会对象" <%= profile && profile.purpose === '寻找短期约会对象' ? 'checked' : '' %>> B. 寻找短期约会对象</label>
          <label><input type="radio" name="purpose" value="顺其自然，拓展社交" <%= profile && profile.purpose === '顺其自然，拓展社交' ? 'checked' : '' %>> C. 顺其自然，拓展社交</label>
        </div>
      </div>

      <div class="form-group">
        <label>5. 我的学历阶段：</label>
        <div class="option-group">
          <label><input type="radio" name="my_grade" value="大一" <%= profile && profile.my_grade === '大一' ? 'checked' : '' %> required> A. 大一</label>
          <label><input type="radio" name="my_grade" value="大二" <%= profile && profile.my_grade === '大二' ? 'checked' : '' %>> B. 大二</label>
          <label><input type="radio" name="my_grade" value="大三" <%= profile && profile.my_grade === '大三' ? 'checked' : '' %>> C. 大三</label>
          <label><input type="radio" name="my_grade" value="大四" <%= profile && profile.my_grade === '大四' ? 'checked' : '' %>> D. 大四</label>
          <label><input type="radio" name="my_grade" value="研一" <%= profile && profile.my_grade === '研一' ? 'checked' : '' %>> E. 研一</label>
          <label><input type="radio" name="my_grade" value="研二" <%= profile && profile.my_grade === '研二' ? 'checked' : '' %>> F. 研二</label>
          <label><input type="radio" name="my_grade" value="研三" <%= profile && profile.my_grade === '研三' ? 'checked' : '' %>> G. 研三</label>
          <label><input type="radio" name="my_grade" value="博一" <%= profile && profile.my_grade === '博一' ? 'checked' : '' %>> H. 博一</label>
          <label><input type="radio" name="my_grade" value="博二" <%= profile && profile.my_grade === '博二' ? 'checked' : '' %>> I. 博二</label>
          <label><input type="radio" name="my_grade" value="博三" <%= profile && profile.my_grade === '博三' ? 'checked' : '' %>> J. 博三</label>
          <label><input type="radio" name="my_grade" value="博四" <%= profile && profile.my_grade === '博四' ? 'checked' : '' %>> K. 博四</label>
          <label><input type="radio" name="my_grade" value="博五" <%= profile && profile.my_grade === '博五' ? 'checked' : '' %>> L. 博五</label>
          <label><input type="radio" name="my_grade" value="已毕业校友" <%= profile && profile.my_grade === '已毕业校友' ? 'checked' : '' %>> M. 已毕业校友</label>
        </div>
      </div>

      <div class="form-group">
        <label>6. 我可接受的对象年龄差（相对于我）：</label>
        <div class="range-container">
          <input type="range" class="range-slider" name="age_diff_min" id="ageDiffMin" min="-10" max="0" value="<%= profile && profile.age_diff_min ? profile.age_diff_min : -5 %>" oninput="updateAgeDiffDisplay()">
          <div class="range-labels">
            <span>-10岁</span>
            <span>0岁</span>
            <span>+10岁</span>
          </div>
          <div class="range-value" id="ageDiffMinValue">可接受比我小 <%= profile && profile.age_diff_min ? Math.abs(profile.age_diff_min) : 5 %> 岁</div>

          <input type="range" class="range-slider" name="age_diff_max" id="ageDiffMax" min="0" max="10" value="<%= profile && profile.age_diff_max ? profile.age_diff_max : 5 %>" oninput="updateAgeDiffDisplay()">
          <div class="range-value" id="ageDiffMaxValue">可接受比我大 <%= profile && profile.age_diff_max ? profile.age_diff_max : 5 %> 岁</div>
        </div>
      </div>

      <div class="form-group">
        <label>7. 我目前常驻的校区是：</label>
        <div class="option-group">
          <label><input type="radio" name="campus" value="宝山" <%= profile && profile.campus === '宝山' ? 'checked' : '' %> required> A. 宝山</label>
          <label><input type="radio" name="campus" value="嘉定" <%= profile && profile.campus === '嘉定' ? 'checked' : '' %>> B. 嘉定</label>
          <label><input type="radio" name="campus" value="延长" <%= profile && profile.campus === '延长' ? 'checked' : '' %>> C. 延长</label>
        </div>
      </div>

      <div class="form-group">
        <label>8. 我可接受对象所在的校区（可多选）：</label>
        <div class="checkbox-group-grid">
          <label><input type="checkbox" name="accepted_campus" value="宝山" <%= profile && profile.accepted_campus && profile.accepted_campus.includes('宝山') ? 'checked' : '' %>> A. 宝山</label>
          <label><input type="checkbox" name="accepted_campus" value="嘉定" <%= profile && profile.accepted_campus && profile.accepted_campus.includes('嘉定') ? 'checked' : '' %>> B. 嘉定</label>
          <label><input type="checkbox" name="accepted_campus" value="延长" <%= profile && profile.accepted_campus && profile.accepted_campus.includes('延长') ? 'checked' : '' %>> C. 延长</label>
        </div>
      </div>

      <div class="form-group">
        <label>9. 我的身高（cm）：</label>
        <div class="range-container">
          <input type="range" class="range-slider" name="height_min" id="heightMin" min="140" max="200" value="<%= profile && profile.height_min ? profile.height_min : 160 %>" oninput="updateHeightDisplay()">
          <div class="range-labels">
            <span>140cm</span>
            <span>170cm</span>
            <span>200cm</span>
          </div>
          <div class="range-value" id="heightMinValue">最低 <%= profile && profile.height_min ? profile.height_min : 160 %> cm</div>

          <input type="range" class="range-slider" name="height_max" id="heightMax" min="140" max="210" value="<%= profile && profile.height_max ? profile.height_max : 180 %>" oninput="updateHeightDisplay()">
          <div class="range-labels">
            <span>140cm</span>
            <span>175cm</span>
            <span>210cm</span>
          </div>
          <div class="range-value" id="heightMaxValue">最高 <%= profile && profile.height_max ? profile.height_max : 180 %> cm</div>
        </div>
      </div>

      <div class="form-group">
        <label>10. 我对匹配对象的身高偏好（cm）：</label>
        <div class="range-container">
          <input type="range" class="range-slider" name="preferred_height_min" id="preferredHeightMin" min="140" max="200" value="<%= profile && profile.preferred_height_min ? profile.preferred_height_min : 160 %>" oninput="updatePreferredHeightDisplay()">
          <div class="range-labels">
            <span>140cm</span>
            <span>170cm</span>
            <span>200cm</span>
          </div>
          <div class="range-value" id="preferredHeightMinValue">最低 <%= profile && profile.preferred_height_min ? profile.preferred_height_min : 160 %> cm</div>

          <input type="range" class="range-slider" name="preferred_height_max" id="preferredHeightMax" min="140" max="210" value="<%= profile && profile.preferred_height_max ? profile.preferred_height_max : 180 %>" oninput="updatePreferredHeightDisplay()">
          <div class="range-labels">
            <span>140cm</span>
            <span>175cm</span>
            <span>210cm</span>
          </div>
          <div class="range-value" id="preferredHeightMaxValue">最高 <%= profile && profile.preferred_height_max ? profile.preferred_height_max : 180 %> cm</div>
        </div>
      </div>
    </div>

    <!-- 二、择偶偏好 -->
    <div class="form-section">
      <h3 style="color: #e74c3c; margin: 20px 0 15px;">二、择偶偏好</h3>

      <div class="form-group">
        <label>11. 我的家乡位于：</label>
        <select name="hometown" class="province-select" required>
          <option value="">请选择省份</option>
          <option value="上海市" <%= profile && profile.hometown === '上海市' ? 'selected' : '' %>>上海市</option>
          <option value="江苏省" <%= profile && profile.hometown === '江苏省' ? 'selected' : '' %>>江苏省</option>
          <option value="浙江省" <%= profile && profile.hometown === '浙江省' ? 'selected' : '' %>>浙江省</option>
          <option value="安徽省" <%= profile && profile.hometown === '安徽省' ? 'selected' : '' %>>安徽省</option>
          <option value="山东省" <%= profile && profile.hometown === '山东省' ? 'selected' : '' %>>山东省</option>
          <option value="福建省" <%= profile && profile.hometown === '福建省' ? 'selected' : '' %>>福建省</option>
          <option value="江西省" <%= profile && profile.hometown === '江西省' ? 'selected' : '' %>>江西省</option>
          <option value="广东省" <%= profile && profile.hometown === '广东省' ? 'selected' : '' %>>广东省</option>
          <option value="广西壮族自治区" <%= profile && profile.hometown === '广西壮族自治区' ? 'selected' : '' %>>广西壮族自治区</option>
          <option value="海南省" <%= profile && profile.hometown === '海南省' ? 'selected' : '' %>>海南省</option>
          <option value="北京市" <%= profile && profile.hometown === '北京市' ? 'selected' : '' %>>北京市</option>
          <option value="天津市" <%= profile && profile.hometown === '天津市' ? 'selected' : '' %>>天津市</option>
          <option value="河北省" <%= profile && profile.hometown === '河北省' ? 'selected' : '' %>>河北省</option>
          <option value="山西省" <%= profile && profile.hometown === '山西省' ? 'selected' : '' %>>山西省</option>
          <option value="内蒙古自治区" <%= profile && profile.hometown === '内蒙古自治区' ? 'selected' : '' %>>内蒙古自治区</option>
          <option value="辽宁省" <%= profile && profile.hometown === '辽宁省' ? 'selected' : '' %>>辽宁省</option>
          <option value="吉林省" <%= profile && profile.hometown === '吉林省' ? 'selected' : '' %>>吉林省</option>
          <option value="黑龙江省" <%= profile && profile.hometown === '黑龙江省' ? 'selected' : '' %>>黑龙江省</option>
          <option value="河南省" <%= profile && profile.hometown === '河南省' ? 'selected' : '' %>>河南省</option>
          <option value="湖北省" <%= profile && profile.hometown === '湖北省' ? 'selected' : '' %>>湖北省</option>
          <option value="湖南省" <%= profile && profile.hometown === '湖南省' ? 'selected' : '' %>>湖南省</option>
          <option value="四川省" <%= profile && profile.hometown === '四川省' ? 'selected' : '' %>>四川省</option>
          <option value="重庆市" <%= profile && profile.hometown === '重庆市' ? 'selected' : '' %>>重庆市</option>
          <option value="贵州省" <%= profile && profile.hometown === '贵州省' ? 'selected' : '' %>>贵州省</option>
          <option value="云南省" <%= profile && profile.hometown === '云南省' ? 'selected' : '' %>>云南省</option>
          <option value="西藏自治区" <%= profile && profile.hometown === '西藏自治区' ? 'selected' : '' %>>西藏自治区</option>
          <option value="陕西省" <%= profile && profile.hometown === '陕西省' ? 'selected' : '' %>>陕西省</option>
          <option value="甘肃省" <%= profile && profile.hometown === '甘肃省' ? 'selected' : '' %>>甘肃省</option>
