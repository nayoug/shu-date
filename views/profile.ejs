          <label class="interest-tag"><input type="checkbox" name="interests" value="生活方式与社交圈-剧本杀与密室逃脱" <%= profile && profile.interests && profile.interests.includes('生活方式与社交圈-剧本杀与密室逃脱') ? 'checked' : '' %>> 剧本杀与密室逃脱</label>
