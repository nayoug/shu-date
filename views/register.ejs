<div class="card" style="max-width: 500px; margin: 0 auto;">
  <h2>📝 注册</h2>
  <form action="/register" method="POST" onsubmit="return handleSubmit(event)">
    <div class="form-group">
      <label for="email">学校邮箱</label>
      <div style="display: flex; align-items: center; gap: 0;">
        <input type="text" id="emailPrefix" placeholder="请输入学校邮箱" value="<%= typeof email !== 'undefined' && email ? email.replace('@shu.edu.cn', '') : '' %>" required style="flex: 1; border-radius: 6px 0 0 6px; border-right: none;">
        <span style="background: #f0f0f0; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 0 6px 6px 0; color: #666; font-size: 14px; white-space: nowrap;">@shu.edu.cn</span>
      </div>
      <input type="hidden" name="email" id="emailFull">
      <p class="hint">请使用 @shu.edu.cn 结尾的学校邮箱</p>
    </div>
    <div class="form-group">
      <label for="password">密码</label>
      <input type="password" id="password" name="password" placeholder="至少6位" autocomplete="new-password" minlength="6" required>
    </div>
    <div class="form-group">
      <label for="name">昵称（可选）</label>
      <input type="text" id="name" name="name" placeholder="显示名称" autocomplete="nickname">
    </div>
    <button type="submit" class="btn">注册并发送验证邮件</button>
  </form>
  <p style="margin-top: 20px; text-align: center;">
    已有账号？<a href="/login">立即登录</a>
  </p>
</div>

<script>
function handleSubmit(e) {
  const prefix = document.getElementById('emailPrefix').value.trim();
  if (!prefix) {
    alert('请输入学校邮箱');
    return false;
  }
  document.getElementById('emailFull').value = prefix + '@shu.edu.cn';
  return true;
}
</script>