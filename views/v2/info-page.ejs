<!doctype html>
<html lang="zh-CN">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body class="v2-page" data-page="<%= pageKey %>">
  <%- include('partials/navbar', { pageKey, user, nickname, hasProfile }) %>
  <main class="app-main">
    <section class="page-intro reveal">
      <div>
        <p class="page-intro__eyebrow"><%= pageKey === 'privacy' ? '隐私政策' : '使用说明' %></p>
        <h1 class="page-intro__title"><%= pageTitle %></h1>
        <p class="page-intro__text"><%= lead %></p>
      </div>
      <div class="page-intro__meta">
        <span class="pill"><%= pageKey === 'privacy' ? '/privacy' : '/guide' %></span>
        <span class="pill">最后更新 <%= updatedAt %></span>
      </div>
    </section>

    <section class="page-frame">
      <aside class="page-side">
        <div class="surface surface--soft reveal">
          <div class="surface__head">
            <h2 class="surface__title">阅读建议</h2>
          </div>
          <ul class="side-list">
            <li><strong>先看与你最相关的部分</strong><p>如果你是首次使用，建议先阅读使用说明；如果关心数据处理方式，可以优先看隐私政策。</p></li>
            <li><strong>遇到问题先看最后一节</strong><p>联系方式、删除说明和边界提示通常会放在靠后的部分。</p></li>
            <li><strong>需要时可以随时返回</strong><p>你可以在首页、设置页或页脚里重新进入这些说明页面。</p></li>
          </ul>
        </div>
      </aside>

      <section class="surface reveal">
        <div class="surface__head">
          <h2 class="surface__title"><%= pageTitle %></h2>
          <p class="surface__text">以下为当前版本公开展示的说明内容。</p>
        </div>
        <div class="info-stack">
          <% sections.forEach(function(section) { %>
            <section>
              <h2><%= section.title %></h2>
              <% if (section.paragraphs) { %>
                <% section.paragraphs.forEach(function(paragraph) { %>
                  <p><%= paragraph %></p>
                <% }); %>
              <% } %>
              <% if (section.bullets) { %>
                <ul>
                  <% section.bullets.forEach(function(item) { %>
                    <li><%= item %></li>
                  <% }); %>
                </ul>
              <% } %>
            </section>
          <% }); %>
        </div>
      </section>
    </section>
  </main>
  <%- include('partials/footer', { user }) %>
  <script src="/v2/assets/app.js"></script>
</body>
</html>

