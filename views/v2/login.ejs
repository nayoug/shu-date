<!doctype html>
<html lang="zh-CN">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body class="v2-page" data-page="<%= pageKey %>">
  <%- include('partials/navbar', { pageKey, user: null, nickname: null, hasProfile: false }) %>
  <main class="app-main">
    <% const safeLoginMethod = typeof loginMethod !== 'undefined' && loginMethod ? loginMethod : 'login'; %>
    <% const safeMessage = typeof message !== 'undefined' ? message : ''; %>
    <% const safeMessageType = typeof messageType !== 'undefined' ? messageType : ''; %>
    <% const safeEmail = typeof email !== 'undefined' && email ? email : ''; %>
    <% const safeNickname = typeof nickname !== 'undefined' && nickname ? nickname : ''; %>
    <% const activeMethod = safeLoginMethod; %>
    <% const tone = safeMessageType === 'error' ? 'danger' : (safeMessageType || 'info'); %>

    <section class="page-intro reveal">
      <div>
        <p class="page-intro__eyebrow">账号入口</p>
        <h1 class="page-intro__title"><%= activeMethod === 'register' ? '先注册，再继续填写资料和查看匹配' : '先登录，再继续填写资料和查看匹配' %></h1>
        <p class="page-intro__text">新版登录页继续复用当前后端表单提交和错误回显，只改页面结构、移动端层级和主题体验，不改变账户逻辑。</p>
      </div>
      <div class="page-intro__meta">
        <span class="pill">/login</span>
        <span class="pill pill--system">@shu.edu.cn</span>
      </div>
    </section>

    <section class="page-frame page-frame--wide">
      <aside class="page-side page-side--stacked">
        <div class="surface surface--soft reveal">
          <div class="surface__head">
            <h2 class="surface__title">这版认证页先解决什么</h2>
            <p class="surface__text">把登录、注册、忘记密码和重置密码做成一套风格统一、适合手机的入口，而不是继续堆在旧页面里。</p>
          </div>
          <ul class="side-list">
            <li><strong>错误提示留在当前页</strong><p>登录失败、注册失败和密码不一致时，不再把用户扔回另一套界面。</p></li>
            <li><strong>邮箱和昵称回填</strong><p>重新提交前保留用户已经输入的关键信息，降低二次操作成本。</p></li>
            <li><strong>暗色模式先在认证页落地</strong><p>这页保留独立的主题开关，方便你直接看浅色和深色的实际区别。</p></li>
          </ul>
        </div>

        <div class="surface reveal">
          <div class="surface__head">
            <h2 class="surface__title">页面内主题切换</h2>
            <p class="surface__text">为了方便演示，主题切换不只放在顶部导航，在表单旁边也放了一组可见开关。</p>
          </div>
          <div class="theme-switch theme-switch--inline" role="group" aria-label="外观模式">
            <button class="theme-switch__option" type="button" data-theme-option="system" aria-pressed="false">跟随系统</button>
            <button class="theme-switch__option" type="button" data-theme-option="light" aria-pressed="false">浅色</button>
            <button class="theme-switch__option" type="button" data-theme-option="dark" aria-pressed="false">深色</button>
          </div>
          <p class="theme-switch__summary" data-theme-summary>当前：跟随系统</p>
        </div>
      </aside>

      <section class="surface reveal">
        <div class="surface__head">
          <h2 class="surface__title">校园邮箱账号</h2>
          <p class="surface__text">保留现有表单 action：<code>POST /register</code> 与 <code>POST /login</code>，这版只动视觉和交互壳层。</p>
        </div>

        <div class="auth-tabs">
          <a class="toggle-button <%= activeMethod === 'register' ? 'is-active' : '' %>" href="/login?method=register<%= email ? `&email=${encodeURIComponent(email)}` : '' %>" aria-current="<%= activeMethod === 'register' ? 'page' : 'false' %>">注册</a>
          <a class="toggle-button <%= activeMethod === 'login' ? 'is-active' : '' %>" href="/login?method=login<%= email ? `&email=${encodeURIComponent(email)}` : '' %>" aria-current="<%= activeMethod === 'login' ? 'page' : 'false' %>">登录</a>
        </div>

        <% if (message) { %>
          <div class="status-banner status-banner--<%= tone %>">
            <strong class="status-banner__title"><%= tone === 'success' ? '操作完成' : '请先处理这个问题' %></strong>
            <p class="status-banner__body"><%= safeMessage %></p>
          </div>
        <% } %>

        <% if (activeMethod === 'register') { %>
          <form action="/register" method="POST" class="fields">
            <div class="field">
              <label for="register-nickname">昵称</label>
              <input id="register-nickname" name="nickname" type="text" value="<%= safeNickname %>" placeholder="给自己起个好记的名字" autocomplete="nickname" required>
            </div>
            <div class="field">
              <label for="register-email">学校邮箱</label>
              <input id="register-email" name="email" type="email" value="<%= safeEmail %>" placeholder="name@shu.edu.cn" autocomplete="email" autocapitalize="none" autocorrect="off" inputmode="email" required>
            </div>
            <div class="field">
              <label for="register-password">设置密码</label>
              <input id="register-password" name="password" type="password" placeholder="至少 6 位" autocomplete="new-password" minlength="6" required>
            </div>
            <div class="field">
              <label for="register-confirm-password">确认密码</label>
              <input id="register-confirm-password" name="confirmPassword" type="password" placeholder="再输入一次密码" autocomplete="new-password" minlength="6" required>
            </div>
            <div class="surface__actions">
              <button class="button" type="submit">注册并发送验证邮件</button>
              <a class="button button--ghost" href="/guide">先看使用说明</a>
            </div>
          </form>
          <div class="result-band">
            <h3>注册后会发生什么</h3>
            <p>系统会给你的学校邮箱发送验证链接。验证完成后即可继续填写资料、查看设置页，并在后续查看正式匹配结果。</p>
            <div class="result-band__meta">
              <span class="pill">邮箱验证</span>
              <span class="pill">昵称保留</span>
              <span class="pill">密码确认</span>
            </div>
          </div>
        <% } else { %>
          <form action="/login" method="POST" class="fields">
            <div class="field">
              <label for="login-email">学校邮箱</label>
              <input id="login-email" name="email" type="email" value="<%= safeEmail %>" placeholder="name@shu.edu.cn" autocomplete="username" autocapitalize="none" autocorrect="off" inputmode="email" required>
            </div>
            <div class="field">
              <label for="login-password">密码</label>
              <input id="login-password" name="password" type="password" placeholder="输入你的登录密码" autocomplete="current-password" required>
            </div>
            <div class="surface__actions">
              <button class="button" type="submit">登录并继续</button>
              <a class="button button--ghost" href="/forgot">忘记密码</a>
            </div>
          </form>
          <div class="result-band">
            <h3>登录后可以去哪里</h3>
            <p>新版已经接入首页、问卷、匹配、设置、通知、说明和后台入口，主流程与管理入口都能在同一套壳层里体验。</p>
            <div class="result-band__meta">
              <span class="pill">/profile</span>`r`n              <span class="pill">/matches</span>`r`n              <span class="pill">/settings</span>
            </div>
          </div>
        <% } %>

        <p class="legacy-tip">目前只支持 <code>@shu.edu.cn</code> 邮箱。邮箱验证、密码重置成功后的跳转仍然沿用当前主线行为。</p>
      </section>
    </section>
  </main>
  <%- include('partials/footer', { user: null }) %>
  <script src="/v2/assets/app.js"></script>
</body>
</html>





