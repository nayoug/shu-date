<%
  const currentClassicUrl = typeof switchToClassicUrl !== 'undefined' ? switchToClassicUrl : '/experience/classic';
%>
<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__lead">
      <p class="microcopy">心有所SHU</p>
      <p class="site-footer__brand">校园匹配</p>
      <p class="site-footer__text">在这里继续查看首页、问卷、匹配、通知、设置和公开说明页面。</p>
    </div>
    <div class="site-footer__links">
      <a href="/">主页</a>
      <a href="/guide">使用说明</a>
      <a href="/privacy">隐私政策</a>
      <% if (user) { %>
        <a href="/notifications">通知</a>
        <a href="/settings">设置</a>
      <% } %>
    </div>
    <div class="v2-footer-actions">
      <a class="button button--ghost button--sm" href="<%= currentClassicUrl %>">返回经典版</a>
      <a class="v2-classic-link" href="/matches">继续查看本周匹配</a>
    </div>
  </div>
</footer>



