<!doctype html>
<html lang="zh-CN">
<head>
  <%- include('partials/head', { title: '修改密码' }) %>
</head>
<body class="v2-page" data-page="<%= pageKey %>">
  <%- include('partials/navbar', { pageKey, user, nickname, hasProfile }) %>
  <main class="app-main">
    <% const tone = passwordMessageType === 'error' ? 'danger' : (passwordMessageType || 'info'); %>
    <section class="page-intro reveal">
      <div>
        <p class="page-intro__eyebrow">修改密码</p>
        <h1 class="page-intro__title">修改你的登录密码</h1>
        <p class="page-intro__text">输入当前密码并设置新的密码，保存后会直接在当前页给出结果提示。</p>
      </div>
      <div class="page-intro__meta">
        <span class="pill">/settings/password</span>
      </div>
    </section>

    <section class="page-frame">
      <aside class="page-side">
        <div class="surface surface--soft reveal">
          <div class="surface__head">
            <h2 class="surface__title">提交前确认</h2>
          </div>
          <ul class="side-list">
            <li><strong>三项都要填写</strong><p>当前密码、新密码和确认密码都需要填写完整后才能提交。</p></li>
            <li><strong>新密码至少 6 位</strong><p>请设置一个容易记住、又不易被猜到的新密码。</p></li>
            <li><strong>结果直接留在当前页</strong><p>失败和成功提示都会停留在当前页面里，方便立即确认结果。</p></li>
          </ul>
        </div>
      </aside>

      <section class="surface reveal">
        <div class="surface__head">
          <h2 class="surface__title">修改密码</h2>
          <p class="surface__text">修改成功后，下次登录将使用新密码。</p>
        </div>
        <% if (passwordMessage) { %>
          <div class="status-banner status-banner--<%= tone %>">
            <strong class="status-banner__title"><%= tone === 'success' ? '密码已更新' : '请先处理这个问题' %></strong>
            <p class="status-banner__body"><%= passwordMessage %></p>
          </div>
        <% } %>
        <form action="/settings/password" method="POST" class="fields">
          <div class="field">
            <label for="current-password">当前密码</label>
            <input id="current-password" name="currentPassword" type="password" placeholder="若之前未设置密码则留空" autocomplete="current-password">
          </div>
          <div class="field">
            <label for="new-password">新密码</label>
            <input id="new-password" name="newPassword" type="password" placeholder="至少 6 位" minlength="6" autocomplete="new-password">
          </div>
          <div class="field">
            <label for="confirm-password">确认新密码</label>
            <input id="confirm-password" name="confirmPassword" type="password" placeholder="再输入一次新密码" minlength="6" autocomplete="new-password">
          </div>
          <div class="surface__actions">
            <button class="button" type="submit">保存新密码</button>
            <a class="button button--ghost" href="/settings">返回设置</a>
          </div>
        </form>
      </section>
    </section>
  </main>
  <%- include('partials/footer', { user }) %>
  <script src="/v2/assets/app.js"></script>
</body>
</html>

