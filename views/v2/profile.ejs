<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>填写问卷 - 心有所SHU</title>
  <script src="/v2/assets/theme-init.js"></script>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/v2/assets/styles.css">
  <%- include('../partials/head-icons') %>
  <% if (typeof isDev !== 'undefined' && isDev) { %>
  <link rel="stylesheet" href="/css/dev-tools.css">
  <% } %>
  <style>
.option-group {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .option-group label {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .option-group label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .option-group label.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .option-group input[type="radio"] {
      width: auto;
      margin: 0;
    }

    /* Range slider styles */
    .range-container {
      padding: 10px 0;
    }
    .range-slider {
      width: 100%;
      margin: 10px 0;
    }
    .range-labels {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #666;
    }
    .range-value {
      text-align: center;
      font-weight: 600;
      color: #e74c3c;
      margin-top: 8px;
    }

    /* Multi-select checkbox group */
    .checkbox-group-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }
    .checkbox-group-grid label {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .checkbox-group-grid label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .checkbox-group-grid label.checked {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .checkbox-group-grid input[type="checkbox"] {
      width: auto;
      margin: 0;
    }

    /* Province select */
    .province-select {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      font-size: 14px;
    }

    /* 5-point scale for new questions */
    .scale-5 {
      display: flex;
      gap: 8px;
    }
    .scale-5 label {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 12px 8px;
      border-radius: 10px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      text-align: center;
      font-size: 13px;
      transition: all 0.2s;
    }
    .scale-5 label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .scale-5 label.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .scale-5 input[type="radio"] {
      width: auto;
      margin-bottom: 6px;
    }
    .scale-5 .scale-endpoints {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #888;
      margin-bottom: 8px;
    }

    /* Interest tags */
    .interest-category {
      margin-bottom: 16px;
    }
    .interest-category-title {
      font-weight: 600;
      color: #e74c3c;
      margin-bottom: 10px;
      font-size: 14px;
    }
    .interest-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .interest-tag {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 20px;
      border: 1px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      transition: all 0.2s;
    }
    .interest-tag:hover {
      border-color: #e74c3c;
    }
    .interest-tag.selected {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .interest-tag input {
      display: none;
    }
    .interest-counter {
      font-size: 13px;
      color: #666;
      margin-bottom: 12px;
    }

    .form-section {
      border-bottom: 1px solid #eee;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }
    .checkbox-group label {
      display: inline-block;
      margin-right: 15px;
      margin-bottom: 8px;
      cursor: pointer;
      padding: 6px 12px;
      border: 1px solid #ddd;
      border-radius: 6px;
      transition: all 0.2s;
    }
    .checkbox-group label:hover {
      border-color: #e74c3c;
      background: #fff8f6;
    }
    .checkbox-group label.checked {
      border-color: #e74c3c;
      background: #fff0ed;
    }
    .checkbox-group input[type="checkbox"] {
      width: auto;
      margin-right: 5px;
    }

    /* 新的5档选择UI - 水平单行布局 */
    .scale-horizontal {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 5px;
      margin-top: 12px;
    }
    .scale-label-text {
      font-size: 12px;
      color: #888;
      width: 200px;
      flex-shrink: 0;
      word-wrap: break-word;
      white-space: normal;
      line-height: 1.3;
    }
    .scale-label-left_text {
      text-align: right;
      padding-right: 8px;
    }
    .scale-label-right_text {
      text-align: left;
      padding-left: 8px;
    }
    .scale-options-row {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex: 1;
      position: relative;
      min-width: 280px;
      max-width: 320px;
      margin: 0 auto;
    }
    .scale-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      flex: 1;
      max-width: 60px;
    }
    .scale-option .scale-circle {
      min-width: 36px;
    }
    .scale-circle {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 2px solid #e0e0e0;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 600;
      color: #666;
      transition: all 0.2s;
    }
    .scale-option:hover .scale-circle {
      border-color: #e74c3c;
      color: #e74c3c;
    }
    .scale-option.selected .scale-circle {
      border-color: #e74c3c;
      background: #e74c3c;
      color: #fff;
    }
    .scale-option input[type="radio"] {
      display: none;
    }

    /* 双滑块数轴样式 */
    .dual-range-container {
      padding: 15px 10px;
    }
    .dual-range-wrapper {
      position: relative;
      height: 40px;
    }
    .dual-range-track {
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 6px;
      background: #e0e0e0;
      border-radius: 3px;
      transform: translateY(-50%);
    }
    .dual-range-track-highlight {
      position: absolute;
      top: 50%;
      height: 6px;
      background: #e74c3c;
      border-radius: 3px;
      transform: translateY(-50%);
    }
    .dual-range-input {
      position: absolute;
      top: 50%;
      width: 100%;
      height: 6px;
      -webkit-appearance: none;
      appearance: none;
      background: transparent;
      transform: translateY(-50%);
      pointer-events: none;
    }
    .dual-range-input::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #fff;
      border: 3px solid #e74c3c;
      cursor: pointer;
      pointer-events: auto;
      box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }
    .dual-range-input::-moz-range-thumb {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #fff;
      border: 3px solid #e74c3c;
      cursor: pointer;
      pointer-events: auto;
      box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }
    .dual-range-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 12px;
      color: #888;
    }
    .dual-range-value {
      text-align: center;
      font-weight: 600;
      color: #e74c3c;
      margin-top: 12px;
      font-size: 15px;
    }

  .v2-page[data-page="profile"] {
    --primary: var(--accent-strong);
    --muted-foreground: var(--ink-soft);
    --card-foreground: var(--ink);
  }

  .v2-page[data-page="profile"] .site-header {
    position: sticky;
    top: 0;
  }

  .v2-page[data-page="profile"] .page-intro {
    margin-bottom: 1.25rem;
  }

  .v2-page[data-page="profile"] .page-intro__title {
    max-width: 12ch;
    font-size: clamp(2.2rem, 4.8vw, 4.4rem);
  }

  .v2-page[data-page="profile"] .page-intro__text {
    max-width: 56rem;
  }

  .v2-profile-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .v2-profile-layout {
    width: min(var(--content), 100%);
    margin: 0 auto;
    display: block;
  }

  .v2-profile-layout > .page-side {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .v2-profile-main {
    width: 100%;
    min-width: 0;
  }

  .v2-profile-container.container {
    width: 100%;
    max-width: none !important;
    margin: 0;
    padding: 0;
  }

  .v2-page[data-page="profile"] .card,
  .v2-page[data-page="profile"] .lovetype-result-card,
  .v2-page[data-page="profile"] .lovetype-copy-block {
    color: var(--ink);
  }

  .v2-profile-container > .card {
    margin-bottom: 1rem;
    padding: 1.5rem 1.6rem;
    border-radius: var(--radius-lg);
    background: var(--surface-bg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
  }

  .v2-profile-container > .card:last-child {
    margin-bottom: 0;
  }

  .v2-profile-container .form-section:first-child {
    padding-top: 0;
  }

  .v2-profile-container .form-section {
    margin-bottom: 0;
    padding: 1.4rem 0 1.2rem;
    border-bottom: 1px solid var(--line);
  }

  .v2-profile-container .form-section:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .v2-profile-password-card {
    background: var(--surface-soft-bg) !important;
  }

  .v2-profile-password-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .v2-profile-password-grid input {
    background: var(--input-bg) !important;
    border: 1px solid var(--input-line) !important;
    color: var(--ink) !important;
  }

  .v2-profile-password-grid label,
  .v2-page[data-page="profile"] .form-group > label,
  .v2-page[data-page="profile"] .interest-category-title {
    color: var(--ink) !important;
  }

  .v2-page[data-page="profile"] .checkbox-group label,
  .v2-page[data-page="profile"] .checkbox-group-grid label,
  .v2-page[data-page="profile"] .option-group label,
  .v2-page[data-page="profile"] .interest-tag,
  .v2-page[data-page="profile"] .scale-option label,
  .v2-page[data-page="profile"] .scale-5 label {
    background: var(--surface-bg);
    border-color: var(--line);
    color: var(--ink);
    box-shadow: inset 0 0 0 1px rgba(16, 40, 86, 0.04);
  }

  .v2-page[data-page="profile"] .checkbox-group label.checked,
  .v2-page[data-page="profile"] .checkbox-group-grid label.checked,
  .v2-page[data-page="profile"] .option-group label.selected,
  .v2-page[data-page="profile"] .interest-tag.selected,
  .v2-page[data-page="profile"] .scale-5 label.selected {
    background: rgba(58, 134, 255, 0.12);
    border-color: rgba(58, 134, 255, 0.28);
    color: var(--accent-strong);
  }

  .v2-page[data-page="profile"] .province-select,
  .v2-page[data-page="profile"] select,
  .v2-page[data-page="profile"] textarea,
  .v2-page[data-page="profile"] input[type="text"],
  .v2-page[data-page="profile"] input[type="email"],
  .v2-page[data-page="profile"] input[type="number"],
  .v2-page[data-page="profile"] input[type="password"] {
    background: var(--input-bg);
    border-color: var(--input-line);
    color: var(--ink);
  }

  .v2-page[data-page="profile"] .scale-circle {
    background: var(--surface-bg);
    border-color: var(--line);
    color: var(--ink-soft);
  }

  .v2-page[data-page="profile"] .scale-option.selected .scale-circle {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .v2-page[data-page="profile"] .scale-label-text,
  .v2-page[data-page="profile"] .range-labels,
  .v2-page[data-page="profile"] .dual-range-labels,
  .v2-page[data-page="profile"] .interest-counter,
  .v2-page[data-page="profile"] .trait-counter,
  .v2-page[data-page="profile"] .card p,
  .v2-page[data-page="profile"] .form-hint,
  .v2-page[data-page="profile"] small {
    color: var(--ink-soft);
  }

  .v2-page[data-page="profile"] .dual-range-track {
    background: rgba(16, 40, 86, 0.14);
  }

  .v2-page[data-page="profile"] .dual-range-track-highlight,
  .v2-page[data-page="profile"] .range-value,
  .v2-page[data-page="profile"] .dual-range-value {
    color: var(--accent-strong);
    background-color: transparent;
  }

  html[data-theme="dark"] .v2-page[data-page="profile"] .checkbox-group label,
  html[data-theme="dark"] .v2-page[data-page="profile"] .checkbox-group-grid label,
  html[data-theme="dark"] .v2-page[data-page="profile"] .option-group label,
  html[data-theme="dark"] .v2-page[data-page="profile"] .interest-tag,
  html[data-theme="dark"] .v2-page[data-page="profile"] .scale-5 label,
  html[data-theme="dark"] .v2-page[data-page="profile"] .scale-circle,
  html[data-theme="dark"] .v2-page[data-page="profile"] .lovetype-dimension-chip,
  html[data-theme="dark"] .v2-page[data-page="profile"] .lovetype-type-pill {
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  html[data-theme="dark"] .v2-page[data-page="profile"] .dual-range-track {
    background: rgba(255, 255, 255, 0.12);
  }

  html[data-theme="dark"] .v2-page[data-page="profile"] .lovetype-result-card,
  html[data-theme="dark"] .v2-page[data-page="profile"] .lovetype-copy-block {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 960px) {
    .v2-profile-layout > .page-side {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .v2-profile-container.container {
      padding-inline: 0;
    }

    .v2-page[data-page="profile"] .page-intro__title {
      max-width: none;
      font-size: clamp(2rem, 9vw, 3rem);
    }

    .v2-profile-password-grid {
      grid-template-columns: 1fr;
    }
  }
  </style>
</head>
<body class="v2-page" data-page="<%= pageKey %>">
  <% const currentLovetypeResult = typeof lovetypeResult !== 'undefined' ? lovetypeResult : null; %>
  <% const isEditMode = typeof editMode !== 'undefined' ? editMode : false; %>
  <% const lovetypeQuestionList = typeof lovetypeQuestions !== 'undefined' ? lovetypeQuestions : []; %>
  <% const currentShowPassword = typeof showPassword !== 'undefined' && showPassword; %>
  <% const selectedInterestCount = profile && profile.interests ? profile.interests.split(',').filter(t => t).length : 0; %>
  <% const selectedMyTraitsCount = profile && profile.my_traits ? profile.my_traits.split(',').filter(t => t).length : 0; %>
  <% const selectedPartnerTraitsCount = profile && profile.partner_traits ? profile.partner_traits.split(',').filter(t => t).length : 0; %>
  <%- include('partials/navbar', { pageKey, user, nickname, hasProfile }) %>
  <main class="app-main">
    <section class="page-intro reveal">
      <div>
        <p class="page-intro__eyebrow">资料问卷</p>
        <h1 class="page-intro__title"><%= currentLovetypeResult && !isEditMode ? '查看你的问卷资料与恋爱人格结果' : '填写问卷，完善你的匹配资料' %></h1>
        <p class="page-intro__text">你的回答会用于生成 LoveType16 结果，并帮助系统理解你的基本信息、偏好与相处方式。填写完成后，你也可以随时回来修改。</p>
        <div class="v2-profile-status">
          <span class="pill"><%= profile ? '资料已存在' : '首次填写' %></span>
          <span class="pill"><%= currentLovetypeResult && !isEditMode ? '查看结果中' : '编辑问卷中' %></span>
          <span class="pill"><%= user && user.verified ? '邮箱已验证' : '邮箱待验证' %></span>
        </div>
      </div>
      <div class="page-intro__meta">
        <span class="pill">共 <%= lovetypeQuestionList.length %> 题</span>
        <span class="pill"><%= currentLovetypeResult ? '已生成结果' : '填写后生成结果' %></span>
      </div>
    </section>

    <section class="page-frame page-frame--wide v2-profile-layout">
      <aside class="page-side page-side--stacked">
        <div class="surface surface--soft reveal">
          <div class="surface__head">
            <h2 class="surface__title">问卷概览</h2>
            <p class="surface__text">这里会集中展示你的填写状态、邮箱状态、恋爱人格结果，以及已选兴趣与特质。</p>
          </div>
          <div class="v2-profile-summary">
            <div class="v2-profile-summary__row">
              <span>资料状态</span>
              <strong><%= profile ? '已填写' : '首次填写' %></strong>
            </div>
            <div class="v2-profile-summary__row">
              <span>邮箱状态</span>
              <strong><%= user && user.verified ? '已验证' : '待验证' %></strong>
            </div>
            <div class="v2-profile-summary__row">
              <span>LoveType16</span>
              <strong><%= currentLovetypeResult ? currentLovetypeResult.code + ' · ' + currentLovetypeResult.title : '尚未完成测试' %></strong>
            </div>
            <div class="v2-profile-summary__row">
              <span>兴趣与特质</span>
              <strong><%= selectedInterestCount %> 项兴趣 / <%= selectedMyTraitsCount %> 项自评 / <%= selectedPartnerTraitsCount %> 项偏好</strong>
            </div>
          </div>
        </div>

        <div class="surface reveal">
          <div class="surface__head">
            <h2 class="surface__title">填写前提醒</h2>
            <p class="surface__text">问卷结果会影响匹配展示与恋爱人格分析，建议按真实情况填写。提交之后仍可随时回来更新。</p>
          </div>
          <ul class="side-list">
            <li>
              <strong>如实填写更有参考价值</strong>
              <p>系统会结合你的资料、兴趣和偏好生成结果，答案越真实，后续展示越有意义。</p>
            </li>
            <li>
              <strong>提交后仍可修改</strong>
              <p>如果后续想更新偏好、兴趣或补充资料，可以重新回到这里继续编辑并保存。</p>
            </li>
            <li>
              <strong>先完成基础信息再看结果</strong>
              <p>完成问卷后，你可以回到这里查看 LoveType16 分析、已填状态以及后续匹配相关信息。</p>
            </li>
          </ul>
          <div class="surface__actions">
            <a class="button" href="/matches">查看本周匹配</a>
            <a class="button button--ghost" href="/">返回首页</a>
          </div>
        </div>
      </aside>

      <div class="v2-profile-main reveal">
<div class="container v2-profile-container">
    <% if (currentShowPassword) { %>
    <div class="card v2-profile-password-card">
      <h3 class="v2-profile-subtitle">🔐 修改密码</h3>

      <% if (typeof passwordMessage !== 'undefined' && passwordMessage) { %>
        <div class="alert alert-<%= passwordMessageType || 'info' %>" style="margin-bottom: 16px;">
          <%= passwordMessage %>
        </div>
      <% } %>

      <form action="/profile/password" method="POST" class="v2-profile-password-grid">
        <div>
          <label style="display: block; margin-bottom: 6px; font-size: 0.9rem;">当前密码</label>
          <input type="password" name="currentPassword" placeholder="若未设置密码则留空" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">
        </div>
        <div></div>
        <div>
          <label style="display: block; margin-bottom: 6px; font-size: 0.9rem;">新密码</label>
          <input type="password" name="newPassword" placeholder="至少6位" minlength="6" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">
        </div>
        <div>
          <label style="display: block; margin-bottom: 6px; font-size: 0.9rem;">确认新密码</label>
          <input type="password" name="confirmPassword" placeholder="再次输入新密码" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">
        </div>
        <div style="grid-column: 1 / -1;">
          <button type="submit" class="btn btn-secondary">修改密码</button>
        </div>
      </form>

      <div style="margin-top: 16px; text-align: center;">
        <a href="/forgot" style="color: var(--primary); font-size: 0.85rem; text-decoration: underline;">忘记密码</a>
      </div>
    </div>
    <% } %>

    <% if (!currentShowPassword) { %>
