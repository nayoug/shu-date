<!doctype html>
<html lang="zh-CN">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body class="v2-page" data-page="<%= pageKey %>">
  <%- include('partials/navbar', { pageKey, user: null, nickname: null, hasProfile: false }) %>
  <main class="app-main">
    <% const tone = messageType === 'error' ? 'danger' : (messageType || 'info'); %>
    <section class="page-intro reveal">
      <div>
        <p class="page-intro__eyebrow">重置密码</p>
        <h1 class="page-intro__title">设置一个新密码，然后直接回到当前登录状态</h1>
        <p class="page-intro__text">重置成功后仍沿用现有主线逻辑：直接登录并跳回首页。</p>
      </div>
      <div class="page-intro__meta">
        <span class="pill">/reset/<%= code %></span>
      </div>
    </section>

    <section class="page-frame">
      <aside class="page-side">
        <div class="surface surface--soft reveal">
          <div class="surface__head">
            <h2 class="surface__title">提交前确认</h2>
          </div>
          <ul class="side-list">
            <li><strong>新密码至少 6 位</strong><p>这是当前主线真实要求，不在新版里额外加码。</p></li>
            <li><strong>两次输入必须一致</strong><p>如果不一致，错误提示会留在当前新版页面。</p></li>
            <li><strong>链接过期会回到登录</strong><p>失效 token 仍按现有后端规则处理。</p></li>
          </ul>
        </div>
      </aside>

      <section class="surface reveal">
        <div class="surface__head">
          <h2 class="surface__title">重置密码</h2>
          <p class="surface__text">提交到 <code>POST /reset/:code</code>，不改变任何 token 行为。</p>
        </div>
        <% if (message) { %>
          <div class="status-banner status-banner--<%= tone %>">
            <strong class="status-banner__title"><%= tone === 'success' ? '操作完成' : '请先处理这个问题' %></strong>
            <p class="status-banner__body"><%= message %></p>
          </div>
        <% } %>
        <form action="/reset/<%= code %>" method="POST" class="fields">
          <div class="field">
            <label for="reset-password">新密码</label>
            <input id="reset-password" name="password" type="password" placeholder="至少 6 位" autocomplete="new-password" minlength="6" required>
          </div>
          <div class="field">
            <label for="reset-confirm-password">确认新密码</label>
            <input id="reset-confirm-password" name="confirmPassword" type="password" placeholder="再次输入新密码" autocomplete="new-password" minlength="6" required>
          </div>
          <div class="surface__actions">
            <button class="button" type="submit">保存并登录</button>
            <a class="button button--ghost" href="/login?method=login">返回登录</a>
          </div>
        </form>
      </section>
    </section>
  </main>
  <%- include('partials/footer', { user: null }) %>
  <script src="/v2/assets/app.js"></script>
</body>
</html>

